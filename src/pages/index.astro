---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import NotePreview from '../components/NotePreview.astro';
import LinkCard from '../components/LinkCard.astro';
import { sortByDate } from '../utils/collections';
import settings from '../data/settings.json';

const notes = sortByDate(
  (await getCollection('notes')).filter((e) => !e.data.draft)
);
const articles = sortByDate(
  (await getCollection('articles')).filter((e) => !e.data.draft)
);
const links = sortByDate(
  (await getCollection('links')).filter((e) => !e.data.draft)
);

const recentArticles = articles.slice(0, 4);
const recentNotes = notes.slice(0, 6);
const recentLinks = links.slice(0, 4);

---

<PageLayout title={settings.siteTitle}>
  <div class="hero">
    {settings.logo
      ? <img src={settings.logo} alt={settings.siteTitle} class="hero-logo" />
      : <h1>{settings.siteTitle}</h1>
    }
    <p>{settings.siteTagline}</p>
  </div>

  <hr class="hero-line" aria-hidden="true" />

  <section class="home-articles">
    <div class="section-header">
      <h2>Articles</h2>
      <a href="/articles" class="view-all">View all &rarr;</a>
    </div>
    <div class="articles-grid">
      {recentArticles.map((article) => (
        <ContentCard
          title={article.data.title}
          href={`/articles/${article.id}`}
          date={article.data.date}
          updated={article.data.updated}
          maturity={article.data.maturity}
          tags={article.data.tags}
          description={article.data.description}
          collection="articles"
        />
      ))}
    </div>
  </section>

  <section class="home-notes">
    <div class="section-header">
      <h2>Notes</h2>
      <a href="/notes" class="view-all">View all &rarr;</a>
    </div>
    <div class="notes-grid">
      {recentNotes.map((note) => (
        <NotePreview
          title={note.data.title}
          href={`/notes/${note.id}`}
          date={note.data.date}
          updated={note.data.updated}
          maturity={note.data.maturity}
          description={note.data.description}
        />
      ))}
    </div>
  </section>

  <!-- Links: full width below -->
  <section class="home-links">
    <div class="section-header">
      <h2>Links</h2>
      <a href="/links" class="view-all">View all &rarr;</a>
    </div>
    <div class="links-grid">
      {recentLinks.map((link) => (
        <LinkCard
          title={link.data.title}
          href={`/links/${link.id}`}
          url={link.data.url}
          date={link.data.date}
          maturity={link.data.maturity}
          tags={link.data.tags}
          description={link.data.description}
        />
      ))}
    </div>
  </section>
</PageLayout>

<style is:global>
  /* Hero */
  .hero {
    margin-block-end: var(--space-xl);
    padding-block: var(--space-md) var(--space-sm);
  }
  .hero-logo {
    display: block;
    height: auto;
    max-height: 18rem;
    width: auto;
    margin-block-end: -1.5rem; /* pull tagline up into logo's bottom whitespace */
    margin-inline-start: -1rem; /* compensate for whitespace in logo image */
  }
  .hero h1 {
    margin-block-end: var(--space-md);
  }
  .hero p {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    padding-inline-start: 3rem; /* align with the M in the logo */
  }

  /* Gradient accent line */
  .hero-line {
    border: none;
    height: 2px;
    background: linear-gradient(to right, var(--color-accent), var(--color-accent-2), transparent);
    margin-block-end: var(--space-3xl);
    max-width: 20rem;
    opacity: 0.5;
  }

  /* Section spacing */
  .home-articles,
  .home-notes {
    margin-block-end: var(--space-3xl);
  }

  /* Section headers */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-block-end: var(--space-lg);
  }
  .section-header h2 {
    font-size: 1.3rem;
    margin: 0;
  }
  .view-all {
    font-size: 0.85rem;
    white-space: nowrap;
  }

  /* Articles 2x2 grid */
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }
  @media (max-width: 480px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Notes grid */
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-md);
  }

  /* Links full-width */
  .home-links {
    margin-block-end: var(--space-2xl);
  }
  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-lg);
  }
</style>
