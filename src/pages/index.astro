---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SketchyFilter from '../components/SketchyFilter.astro';
import MosaicCard from '../components/MosaicCard.astro';
import { getAllContent, sortByDate } from '../utils/collections';
import settings from '../data/settings.json';

const allContent = sortByDate(await getAllContent());

// Main feed: all content types except hubs, stubs, and generated-only
const mainFeedEligible = allContent.filter((e) => {
  const data = e.data as any;
  if (data.hub === true) return false;
  if (data.ai === 'generated') return false;
  if (e.collection === 'library') return false;
  if (e.collection === 'field-notes') return !data.tags?.includes('about');
  if (data.develops) return false;
  if (e.collection === 'jottings' && data.type === 'quote') return false;
  return true;
});

// Pinned: latest article sits first
const latestArticle = mainFeedEligible.find((e) => e.collection === 'articles');
const feedItems = mainFeedEligible.filter((e) => e !== latestArticle);

// Sidebar: currently reading books
const library = sortByDate(
  (await getCollection('library')).filter((e) => !e.data.draft)
);
const currentlyReading = library.filter((e) => e.data.status === 'reading').slice(0, 3);

// Sidebar: active project hubs
const hubs = allContent
  .filter((e) => (e.data as any).hub === true)
  .slice(0, 8);

const filterCollections = [
  'articles', 'seeds', 'field-notes', 'jottings',
  'weblinks', 'videos',
];
const collectionLabels: Record<string, string> = {
  articles:    'Articles',
  seeds:       'Seeds',
  'field-notes': 'Field Notes',
  jottings:    'Jottings',
  weblinks:    'Weblinks',
  videos:      'Videos',
  library:     'Library',
  experiments: 'Experiments',
  projects:    'Projects',
};
const collectionIcons: Record<string, string> = {
  articles:    '/images/icons/doc.svg',
  seeds:       '/images/icons/bulb.svg',
  'field-notes': '/images/icons/note.svg',
  jottings:    '/images/icons/pencil.svg',
  weblinks:    '/images/icons/globe.svg',
  videos:      '/images/icons/play.svg',
  library:     '/images/icons/bookmark.svg',
  experiments: '/images/icons/flask.svg',
  projects:    '/images/icons/rocket.svg',
};
const maturities = [
  { value: 'draft',      label: '🌱 Draft' },
  { value: 'developing', label: '🌿 Developing' },
  { value: 'solid',      label: '🪴 Solid' },
  { value: 'complete',   label: '🌳 Complete' },
];
const aiLevels = [
  { value: '100% Maai', label: '✍️ 100% Maaike' },
  { value: 'assisted',  label: '✏️ Assisted' },
  { value: 'co-created', label: '✨ Co-created' },
];

function extractBodyPreview(body: string | undefined, maxLen = 220): string {
  if (!body) return '';
  const text = body
    .replace(/<div[^>]*class="tended"[^>]*>[\s\S]*?<\/div>/g, '')
    .replace(/<[^>]+>/g, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^#\s+.*$/gm, '')
    .replace(/^#{2,6}\s+/gm, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/^\s*\d+\.\s+/gm, '')
    .replace(/[*_]{1,2}([^*_]+)[*_]{1,2}/g, '$1')
    .replace(/`[^`]+`/g, '')
    .replace(/\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/g, '$1')
    .replace(/\s+/g, ' ')
    .trim();
  if (text.length <= maxLen) return text;
  const cut = text.lastIndexOf(' ', maxLen);
  return text.slice(0, cut > 0 ? cut : maxLen) + '…';
}
---

<BaseLayout title={settings.siteTitle} description={settings.siteTagline}>
  <SketchyFilter />
  <Header />

  <!-- ═══ HERO ═══ -->
  <section class="home-hero" aria-label="Introduction">
    <div class="hero-inner">
      <div class="hero-top">
        <div class="hero-leaf" aria-hidden="true">
          <svg viewBox="0 0 120 165" fill="none" class="leaf-svg-inline">
            <path d="M60 8 C18 42, 8 85, 18 115 C28 140, 50 155, 60 155 C70 155, 92 140, 102 115 C112 85, 102 42, 60 8Z" fill="#D4E8D4"/>
            <path d="M60 24 C28 52, 20 88, 28 112 C36 132, 52 144, 60 144 C68 144, 84 132, 92 112 C100 88, 92 52, 60 24Z" fill="#7A9B68"/>
            <path d="M60 42 C38 62, 32 90, 40 108 C46 122, 54 130, 60 130 C66 130, 74 122, 80 108 C88 90, 82 62, 60 42Z" fill="#4A6741"/>
            <line x1="60" y1="50" x2="60" y2="125" stroke="#3D5835" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>
            <path d="M60 65 Q45 75, 38 90" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
            <path d="M60 65 Q75 75, 82 90" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
            <path d="M60 85 Q48 92, 42 105" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
            <path d="M60 85 Q72 92, 78 105" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
            <line x1="60" y1="155" x2="60" y2="165" stroke="#6B8E5A" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </div>
        <h1 class="hero-heading">Welcome to my<br>digital garden</h1>
      </div>
      <p class="hero-desc">Hoihoi! I'm Maaike Groenewege: natural language interface designer, linguist, and owner of about 50 fountain pens. This space is where I think in public about language, human machine interaction, AI and stuff.</p>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <svg viewBox="0 0 120 165" fill="none" class="hero-leaf-large">
        <path d="M60 8 C18 42, 8 85, 18 115 C28 140, 50 155, 60 155 C70 155, 92 140, 102 115 C112 85, 102 42, 60 8Z" fill="#D4E8D4"/>
        <path d="M60 24 C28 52, 20 88, 28 112 C36 132, 52 144, 60 144 C68 144, 84 132, 92 112 C100 88, 92 52, 60 24Z" fill="#7A9B68"/>
        <path d="M60 42 C38 62, 32 90, 40 108 C46 122, 54 130, 60 130 C66 130, 74 122, 80 108 C88 90, 82 62, 60 42Z" fill="#4A6741"/>
        <line x1="60" y1="50" x2="60" y2="125" stroke="#3D5835" stroke-width="2.5" stroke-linecap="round" opacity="0.4"/>
        <path d="M60 65 Q45 75, 38 90" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
        <path d="M60 65 Q75 75, 82 90" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
        <path d="M60 85 Q48 92, 42 105" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
        <path d="M60 85 Q72 92, 78 105" stroke="#3D5835" stroke-width="1.5" fill="none" opacity="0.3" stroke-linecap="round"/>
        <line x1="60" y1="155" x2="60" y2="165" stroke="#6B8E5A" stroke-width="4" stroke-linecap="round"/>
      </svg>
    </div>
  </section>

  <hr class="home-divider" />

  <!-- ═══ STREAM ═══ -->
  <main id="main-content" class="home-content">
    <div class="stream-layout">

      <!-- Main feed column -->
      <div class="stream-main">
        <p class="stream-label">Stream</p>

        <!-- Mobile filter (all groups, toggle panel) -->
        <div class="mobile-filter-bar" id="mobile-filter-bar">
          <button class="mobile-filter-toggle" id="mobile-filter-toggle" aria-expanded="false" aria-controls="mobile-filter-panel">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><line x1="2" y1="4" x2="14" y2="4"/><line x1="4" y1="8" x2="12" y2="8"/><line x1="6" y1="12" x2="10" y2="12"/></svg>
            <span>Filters</span>
            <span class="mobile-filter-count" id="mobile-filter-count" hidden>0</span>
          </button>
          <div class="mobile-filter-panel" id="mobile-filter-panel">
            <div class="mobile-filter-group">
              <p class="mobile-filter-group-label">Collection</p>
              <div class="mobile-filter-group-options">
                {filterCollections.map((col) => (
                  <label class="mobile-filter-option">
                    <input type="checkbox" data-mobile-group="collection" value={col} />
                    <span>{collectionLabels[col]}</span>
                  </label>
                ))}
              </div>
            </div>
            <div class="mobile-filter-group">
              <p class="mobile-filter-group-label">Maturity</p>
              <div class="mobile-filter-group-options">
                {maturities.map((m) => (
                  <label class="mobile-filter-option">
                    <input type="checkbox" data-mobile-group="maturity" value={m.value} />
                    <span>{m.label}</span>
                  </label>
                ))}
              </div>
            </div>
            <div class="mobile-filter-group">
              <p class="mobile-filter-group-label">Written by</p>
              <div class="mobile-filter-group-options">
                {aiLevels.map((a) => (
                  <label class="mobile-filter-option">
                    <input type="checkbox" data-mobile-group="ai" value={a.value} />
                    <span>{a.label}</span>
                  </label>
                ))}
              </div>
            </div>
            <button class="mobile-filter-clear" id="mobile-filter-clear">Clear all</button>
          </div>
        </div>

        <div class="stream-feed" id="stream-feed">
          {latestArticle && (() => {
            const data = latestArticle.data as any;
            return (
              <MosaicCard
                title={data.title}
                href={`/articles/${latestArticle.id}`}
                date={data.date}
                updated={data.updated}
                maturity={data.maturity}
                tags={data.tags}
                description={data.description}
                collection="articles"
                pinned={true}
                hero={true}
                ai={data.ai}
                bodyPreview={extractBodyPreview(latestArticle.body, 300)}
              />
            );
          })()}
          {feedItems.map((entry) => {
            const data = entry.data as any;
            const col = entry.collection;
            const href = `/${col}/${entry.id}`;
            const domain = (col === 'jottings' || col === 'weblinks') && data.url
              ? (() => { try { return new URL(data.url).hostname.replace('www.', ''); } catch { return undefined; } })()
              : undefined;
            return (
              <MosaicCard
                title={data.title}
                href={href}
                date={data.date}
                updated={data.updated}
                maturity={data.maturity}
                tags={data.tags}
                description={data.description}
                collection={col}
                jottingType={data.type}
                source={data.source}
                domain={domain}
                url={data.url}
                ai={data.ai}
                bodyPreview={(col === 'articles' || col === 'jottings') ? extractBodyPreview(entry.body) : undefined}
              />
            );
          })}
        </div>
        <p class="stream-empty" id="stream-empty" hidden>No items match the current filters.</p>
        <nav class="stream-pagination" id="stream-pagination" aria-label="Stream pages" hidden>
          <button class="page-btn" id="page-prev" aria-label="Previous page">&larr; Previous</button>
          <span class="page-indicator" id="page-indicator"></span>
          <button class="page-btn" id="page-next" aria-label="Next page">Next &rarr;</button>
        </nav>
      </div>

      <!-- Sidebar: filter panels -->
      <aside class="stream-sidebar" id="stream-sidebar" aria-label="Filters">

        <!-- Collection filter -->
        <div class="filter-panel" data-label="Collection">
          <div class="filter-panel-header">
            <button class="filter-action" id="col-select-all">All</button>
            <button class="filter-action" id="col-clear">Clear</button>
          </div>
          <div class="filter-items">
            {filterCollections.map((col) => (
              <label class="filter-item">
                <span class="filter-checkbox" aria-hidden="true">
                  <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.5" width="10" height="10"><polyline points="2 6 5 9 10 3"/></svg>
                </span>
                <input type="checkbox" class="filter-cb-input sr-only" value={col} data-group="collection" />
                <span class="filter-content">
                  <img src={collectionIcons[col]} alt="" width="15" height="15" class="filter-icon" />
                  <span>{collectionLabels[col]}</span>
                </span>
              </label>
            ))}
          </div>
        </div>

        <!-- Maturity filter -->
        <div class="filter-panel" data-label="Maturity">
          <div class="filter-panel-header">
            <button class="filter-action" id="mat-select-all">All</button>
            <button class="filter-action" id="mat-clear">Clear</button>
          </div>
          <div class="filter-items">
            {maturities.map((m) => (
              <label class="filter-item">
                <span class="filter-checkbox" aria-hidden="true">
                  <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.5" width="10" height="10"><polyline points="2 6 5 9 10 3"/></svg>
                </span>
                <input type="checkbox" class="filter-cb-input sr-only" value={m.value} data-group="maturity" />
                <span class="filter-content"><span>{m.label}</span></span>
              </label>
            ))}
          </div>
        </div>

        <!-- Written by filter -->
        <div class="filter-panel" data-label="Written by">
          <div class="filter-panel-header">
            <button class="filter-action" id="ai-select-all">All</button>
            <button class="filter-action" id="ai-clear">Clear</button>
          </div>
          <div class="filter-items">
            {aiLevels.map((a) => (
              <label class="filter-item">
                <span class="filter-checkbox" aria-hidden="true">
                  <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.5" width="10" height="10"><polyline points="2 6 5 9 10 3"/></svg>
                </span>
                <input type="checkbox" class="filter-cb-input sr-only" value={a.value} data-group="ai" />
                <span class="filter-content"><span>{a.label}</span></span>
              </label>
            ))}
          </div>
        </div>

        <!-- Legend -->
        <details class="legend-card">
          <summary class="legend-summary">Legend</summary>
          <div class="legend-section">
            <p class="legend-section-title">Maturity</p>
            <ul class="legend-list">
              <li>🌱 <strong>Draft:</strong> early idea, rough</li>
              <li>🌿 <strong>Developing:</strong> being worked on</li>
              <li>🪴 <strong>Solid:</strong> reasonably complete</li>
              <li>🌳 <strong>Complete:</strong> done, no plans to revise</li>
            </ul>
          </div>
          <div class="legend-section">
            <p class="legend-section-title">Written by</p>
            <ul class="legend-list">
              <li>✍️ <strong>100% Maaike:</strong> fully written by me, no AI at all</li>
              <li>✏️ <strong>Assisted:</strong> my ideas and writing, AI as editor</li>
              <li>✨ <strong>Co-created:</strong> my ideas and direction, AI generated the content</li>
              <li>⚙️ <strong>Generated:</strong> fully AI generated, usually system loggings</li>
            </ul>
          </div>
        </details>

        <!-- Currently reading -->
        {currentlyReading.length > 0 && (
          <article class="sidebar-card sidebar-card--reading">
            <div class="sidebar-strip">
              <img src="/images/icons/bookmark.svg" alt="" class="sidebar-icon" width="18" height="18" />
              <span class="sidebar-strip-title">Currently reading</span>
            </div>
            <div class="sidebar-body">
              {currentlyReading.map((book) => (
                <a href={`/library/${book.id}`} class="reading-book">
                  {book.data.cover && <img src={book.data.cover} alt="" class="reading-cover" loading="lazy" />}
                  <div>
                    <span class="reading-title">{book.data.title}</span>
                    <span class="reading-author">{book.data.author}</span>
                  </div>
                </a>
              ))}
            </div>
          </article>
        )}

        <!-- Projects -->
        {hubs.length > 0 && (
          <article class="sidebar-card sidebar-card--projects">
            <div class="sidebar-strip">
              <img src="/images/icons/rocket.svg" alt="" class="sidebar-icon" width="18" height="18" />
              <span class="sidebar-strip-title">Projects</span>
            </div>
            <div class="sidebar-body">
              <ul class="projects-list">
                {hubs.map((hub) => (
                  <li>
                    <a href={`/${hub.collection}/${hub.id}`} class="project-link">
                      {(hub.data as any).title}
                    </a>
                  </li>
                ))}
              </ul>
              <a href="/projects" class="sidebar-read-more">All projects &rarr;</a>
            </div>
          </article>
        )}

      </aside>
    </div>

  </main>

  <div class="site-footer-zone">
    <!-- Stay updated -->
    <section class="stay-updated">
      <h2 class="stay-updated-heading">Stay updated</h2>
      <p class="stay-updated-desc">Follow along via RSS, LinkedIn, or the community.</p>
      <div class="stay-updated-links">
        <a href="/rss.xml" class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          RSS
        </a>
        <a href="https://www.linkedin.com/in/maaikegroenewegen" class="btn-outline" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
          LinkedIn
        </a>
        <a href="https://www.convo.club" class="btn-outline" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 2.98.97 4.29L2 22l5.71-.97A9.96 9.96 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm0 18c-1.4 0-2.73-.35-3.9-1l-.28-.16-2.88.49.49-2.88-.17-.28A7.96 7.96 0 014 12c0-4.41 3.59-8 8-8s8 3.59 8 8-3.59 8-8 8z"/></svg>
          Community
        </a>
      </div>
    </section>

    <!-- Webring -->
    <section class="footer-webring" aria-label="Webring">
      <p class="webring-label">Webring</p>
      <div class="webring-row">
        <a href="#">&larr; Previous</a>
        <span class="webring-sep" aria-hidden="true">|</span>
        <a href="#">Random</a>
        <span class="webring-sep" aria-hidden="true">|</span>
        <a href="#">Next &rarr;</a>
      </div>
    </section>

    <Footer />
  </div>
</BaseLayout>

<script>
  const PAGE_SIZE = window.innerWidth <= 800 ? 6 : 10;

  function initStream() {
    const feed       = document.getElementById('stream-feed');
    const empty      = document.getElementById('stream-empty');
    const pagination = document.getElementById('stream-pagination');
    const prevBtn    = document.getElementById('page-prev') as HTMLButtonElement | null;
    const nextBtn    = document.getElementById('page-next') as HTMLButtonElement | null;
    const indicator  = document.getElementById('page-indicator');
    if (!feed) return;

    const allCards = Array.from(feed.querySelectorAll<HTMLElement>('.mosaic-card'));
    const inputs   = Array.from(document.querySelectorAll<HTMLInputElement>('.filter-cb-input'));
    let currentPage = 1;

    function getActiveFilters(group: string): string[] {
      return inputs
        .filter((i) => i.dataset.group === group && i.checked)
        .map((i) => i.value);
    }

    function matchesFilters(card: HTMLElement): boolean {
      const col = card.dataset.collection ?? '';
      const mat = card.dataset.maturity ?? '';
      const ai  = card.dataset.ai ?? '';
      const cf  = getActiveFilters('collection');
      const mf  = getActiveFilters('maturity');
      const af  = getActiveFilters('ai');
      return (cf.length === 0 || cf.includes(col))
          && (mf.length === 0 || mf.includes(mat))
          && (af.length === 0 || af.includes(ai));
    }

    function render() {
      const matching = allCards.filter(matchesFilters);
      const totalPages = Math.max(1, Math.ceil(matching.length / PAGE_SIZE));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * PAGE_SIZE;
      const end   = start + PAGE_SIZE;

      allCards.forEach((card) => { card.style.display = 'none'; });
      matching.slice(start, end).forEach((card) => { card.style.display = ''; });

      if (empty)      empty.hidden = matching.length > 0;
      if (pagination) pagination.hidden = totalPages <= 1;
      if (indicator)  indicator.textContent = `Page ${currentPage} of ${totalPages}`;
      if (prevBtn)    prevBtn.disabled = currentPage === 1;
      if (nextBtn)    nextBtn.disabled = currentPage === totalPages;
    }

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; render(); }
    });
    nextBtn?.addEventListener('click', () => {
      currentPage++; render();
    });

    inputs.forEach((input) => {
      input.addEventListener('change', () => { currentPage = 1; render(); });
    });

    function makeGroupActions(group: string, allId: string, clearId: string) {
      const groupInputs = inputs.filter((i) => i.dataset.group === group);
      document.getElementById(allId)?.addEventListener('click', () => {
        groupInputs.forEach((i) => { i.checked = true; });
        currentPage = 1; render();
      });
      document.getElementById(clearId)?.addEventListener('click', () => {
        groupInputs.forEach((i) => { i.checked = false; });
        currentPage = 1; render();
      });
    }

    makeGroupActions('collection', 'col-select-all', 'col-clear');
    makeGroupActions('maturity',   'mat-select-all', 'mat-clear');
    makeGroupActions('ai',         'ai-select-all',  'ai-clear');

    // Mobile filter panel toggle + sync
    const mobileToggle = document.getElementById('mobile-filter-toggle') as HTMLButtonElement | null;
    const mobilePanel = document.getElementById('mobile-filter-panel') as HTMLElement | null;
    const mobileCount = document.getElementById('mobile-filter-count') as HTMLElement | null;
    const mobileClear = document.getElementById('mobile-filter-clear') as HTMLButtonElement | null;
    const mobileInputs = mobilePanel
      ? Array.from(mobilePanel.querySelectorAll<HTMLInputElement>('input[type="checkbox"]'))
      : [];

    function updateMobileCount() {
      const checked = mobileInputs.filter((i) => i.checked).length;
      if (mobileCount) {
        mobileCount.textContent = String(checked);
        mobileCount.hidden = checked === 0;
      }
    }

    mobileToggle?.addEventListener('click', () => {
      const isOpen = mobilePanel?.classList.contains('is-open');
      mobilePanel?.classList.toggle('is-open', !isOpen);
      mobileToggle.setAttribute('aria-expanded', String(!isOpen));
    });

    mobileInputs.forEach((mInput) => {
      mInput.addEventListener('change', () => {
        // Sync to hidden desktop inputs so render() works
        const group = mInput.dataset.mobileGroup ?? '';
        const desktopInput = inputs.find(
          (i) => (i as HTMLInputElement).dataset.group === group && (i as HTMLInputElement).value === mInput.value
        ) as HTMLInputElement | undefined;
        if (desktopInput) desktopInput.checked = mInput.checked;
        updateMobileCount();
        currentPage = 1;
        render();
      });
    });

    mobileClear?.addEventListener('click', () => {
      mobileInputs.forEach((i) => { i.checked = false; });
      inputs.forEach((i) => { (i as HTMLInputElement).checked = false; });
      updateMobileCount();
      currentPage = 1;
      render();
    });

    render();
  }

  initStream();
  document.addEventListener('astro:after-swap', initStream);
</script>

