---
import { getCollection } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import MosaicCard from '../components/MosaicCard.astro';
import { getAllContent, sortByDate } from '../utils/collections';
import settings from '../data/settings.json';

const allContent = sortByDate(await getAllContent());

// Main feed: everything — articles, seeds, field notes, jottings, weblinks
const mainFeedEligible = allContent.filter((e) => {
  const data = e.data as any;
  if (!['articles', 'seeds', 'field-notes', 'jottings', 'weblinks'].includes(e.collection)) return false;
  if (data.hub === true) return false;
  if (data.ai === 'generated') return false;
  if (e.collection === 'field-notes') return !data.tags?.includes('about');
  if (data.develops) return false;
  if (e.collection === 'jottings' && data.type === 'quote') return false;
  return true;
});

// Pinned: latest article sits first in the stream
const latestArticle = mainFeedEligible.find((e) => e.collection === 'articles');
const feedItems = mainFeedEligible.filter((e) => e !== latestArticle);

// Sidebar: currently reading books
const library = sortByDate(
  (await getCollection('library')).filter((e) => !e.data.draft)
);
const currentlyReading = library.filter((e) => e.data.status === 'reading').slice(0, 3);

// Sidebar: active project hubs
const hubs = allContent
  .filter((e) => (e.data as any).hub === true)
  .slice(0, 8);

const filterCollections = ['articles', 'seeds', 'field-notes', 'jottings', 'weblinks'];
const collectionLabels: Record<string, string> = {
  articles: 'Articles',
  seeds: 'Seeds',
  'field-notes': 'Field Notes',
  jottings: 'Jottings',
  weblinks: 'Weblinks',
};
const doodleFilterIcons: Record<string, string> = {
  articles: '/images/icons/doc.svg',
  seeds: '/images/icons/bulb.svg',
  'field-notes': '/images/icons/note.svg',
  jottings: '/images/icons/pencil.svg',
  weblinks: '/images/icons/globe.svg',
};

function extractBodyPreview(body: string | undefined, maxLen = 220): string {
  if (!body) return '';
  const text = body
    .replace(/<div[^>]*class="tended"[^>]*>[\s\S]*?<\/div>/g, '')
    .replace(/<[^>]+>/g, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^#\s+.*$/gm, '')
    .replace(/^#{2,6}\s+/gm, '')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/^\s*\d+\.\s+/gm, '')
    .replace(/[*_]{1,2}([^*_]+)[*_]{1,2}/g, '$1')
    .replace(/`[^`]+`/g, '')
    .replace(/\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/g, '$1')
    .replace(/\s+/g, ' ')
    .trim();
  if (text.length <= maxLen) return text;
  const cut = text.lastIndexOf(' ', maxLen);
  return text.slice(0, cut > 0 ? cut : maxLen) + '…';
}
---

<PageLayout title={`Stream — ${settings.siteTitle}`}>
  <h1>Stream</h1>
  <p class="stream-description">What's growing, what's on my mind.</p>

  <div class="stream-layout">

    <!-- Main column: filter chips + feed -->
    <div class="stream-main">
      <div class="mosaic-filters" role="group" aria-label="Filter by content type">
        <button class="filter-chip active" data-filter="all">All</button>
        {filterCollections.map((col) => (
          <button class="filter-chip" data-filter={col}>
            {doodleFilterIcons[col] && <img src={doodleFilterIcons[col]} alt="" class="filter-icon" />}
            {collectionLabels[col] || col}
          </button>
        ))}
      </div>

      <div class="stream-feed" id="stream-feed">
        {latestArticle && (() => {
          const data = latestArticle.data as any;
          return (
            <MosaicCard
              title={data.title}
              href={`/articles/${latestArticle.id}`}
              date={data.date}
              updated={data.updated}
              maturity={data.maturity}
              tags={data.tags}
              description={data.description}
              collection="articles"
              pinned={true}
              ai={data.ai}
              bodyPreview={extractBodyPreview(latestArticle.body, 300)}
            />
          );
        })()}
        {feedItems.map((entry) => {
          const data = entry.data as any;
          const col = entry.collection;
          const href = `/${col}/${entry.id}`;
          const domain = (col === 'jottings' || col === 'weblinks') && data.url
            ? (() => { try { return new URL(data.url).hostname.replace('www.', ''); } catch { return undefined; } })()
            : undefined;
          return (
            <MosaicCard
              title={data.title}
              href={href}
              date={data.date}
              updated={data.updated}
              maturity={data.maturity}
              tags={data.tags}
              description={data.description}
              collection={col}
              jottingType={data.type}
              source={data.source}
              domain={domain}
              url={data.url}
              ai={data.ai}
              bodyPreview={(col === 'articles' || col === 'jottings') ? extractBodyPreview(entry.body) : undefined}
            />
          );
        })}
      </div>
    </div>

    <!-- Sidebar: portrait index cards -->
    <aside class="stream-sidebar" id="stream-sidebar">

      {/* About */}
      <article class="sidebar-card sidebar-card--about">
        <div class="sidebar-strip">
          <img src="/images/icons/bulb.svg" alt="" class="sidebar-icon" width="20" height="20" />
          <span class="sidebar-strip-title">About Maai & AI</span>
        </div>
        <div class="sidebar-main">
          <div class="sidebar-body">
            <p class="sidebar-bio">Hoihoi, I'm Maaike: natural language interface designer, linguist and owner of about 50 fountain pens, with notebooks to match. I love public speaking. This digital garden is my space for public thinking.</p>
            <a href="/about" class="sidebar-read-more">Read more →</a>
          </div>
        </div>
      </article>


      {/* Currently reading */}
      {currentlyReading.length > 0 && (
        <article class="sidebar-card sidebar-card--reading">
          <div class="sidebar-strip">
            <img src="/images/icons/bookmark.svg" alt="" class="sidebar-icon" width="20" height="20" />
            <span class="sidebar-strip-title">Currently reading</span>
          </div>
          <div class="sidebar-main">
            <div class="sidebar-body">
              {currentlyReading.map((book) => (
                <a href={`/library/${book.id}`} class="reading-book">
                  {book.data.cover && <img src={book.data.cover} alt="" class="reading-cover" loading="lazy" />}
                  <div>
                    <span class="reading-title">{book.data.title}</span>
                    <span class="reading-author">{book.data.author}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </article>
      )}

      {/* Projects */}
      {hubs.length > 0 && (
        <article class="sidebar-card sidebar-card--projects">
          <div class="sidebar-strip">
            <img src="/images/icons/flask.svg" alt="" class="sidebar-icon" width="20" height="20" />
            <span class="sidebar-strip-title">Projects</span>
          </div>
          <div class="sidebar-main">
            <div class="sidebar-body">
              <ul class="projects-list">
                {hubs.map((hub) => (
                  <li>
                    <a href={`/${hub.collection}/${hub.id}`} class="project-link">
                      {(hub.data as any).title}
                    </a>
                  </li>
                ))}
              </ul>
              <a href="/projects" class="sidebar-read-more">All projects →</a>
            </div>
          </div>
        </article>
      )}

    </aside>
  </div>

</PageLayout>

<script>
  function initStream() {
    // Filter chips
    const chips = document.querySelectorAll<HTMLElement>('.filter-chip');
    const sidebar = document.getElementById('stream-sidebar');
    const feed = document.getElementById('stream-feed');
    if (!feed) return;

    const allCards = Array.from(feed.querySelectorAll<HTMLElement>('.mosaic-card'));

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        const filter = chip.dataset.filter ?? 'all';
        if (sidebar) sidebar.style.display = filter === 'all' ? '' : 'none';
        allCards.forEach((c) => {
          c.style.display = filter === 'all' || c.dataset.collection === filter ? '' : 'none';
        });
      });
    });

  }

  initStream();
  document.addEventListener('astro:after-swap', initStream);
</script>

<style is:global>
  h1 { margin-block-end: var(--space-xs); }

  .stream-description {
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    font-style: italic;
    margin-block-end: var(--space-xl);
  }

  /* Two-column layout */
  .stream-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--space-2xl);
    align-items: start;
  }
  @media (max-width: 800px) {
    .stream-layout {
      grid-template-columns: 1fr;
    }
    .stream-sidebar {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
      order: -1;
    }
  }
  @media (max-width: 500px) {
    .stream-sidebar { grid-template-columns: 1fr; }
  }

  /* Filter chips */
  .mosaic-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-block-end: var(--space-xl);
  }
  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    min-height: 44px;
    border: 1px solid var(--color-border);
    border-radius: 2rem;
    background: var(--color-bg);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .filter-icon { width: 14px; height: 14px; opacity: 0.6; }
  .filter-chip.active .filter-icon { filter: brightness(0) invert(1); opacity: 1; }
  .filter-chip:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .filter-chip.active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  /* Stream feed */
  .stream-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* ── Sidebar index cards (landscape, left strip) ── */
  .stream-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .sidebar-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    transition: box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .sidebar-card:hover {
    box-shadow: 0 4px 12px var(--color-shadow);
    border-color: transparent;
  }

  /* Colored strip at top: icon left + title */
  .sidebar-strip {
    height: 38px;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    padding-inline: 0.75rem;
    flex-shrink: 0;
    border-block-end: 3px double var(--color-border);
  }
  .sidebar-icon {
    display: block;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .sidebar-strip-title {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b6258;
    white-space: nowrap;
  }
  :root[data-theme="dark"] .sidebar-strip-title { color: #a89880; }

  /* All strips: single brand-pink tint */
  .sidebar-strip {
    background: #F4F1F2;
    border-block-end: 3px double #B8B0AA;
  }
  :root[data-theme="dark"] .sidebar-strip {
    background: #2a1020;
    border-block-end: 3px double #4a3040;
  }

  /* Icon + title: brand pink */
  .sidebar-icon {
    filter: invert(10%) sepia(90%) saturate(600%) hue-rotate(300deg) brightness(0.75);
  }
  .sidebar-strip-title { color: #A0005A; }
  :root[data-theme="dark"] .sidebar-strip-title { color: #FF4DA6; }

  .sidebar-main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

.sidebar-body {
    padding: 0.75rem 0.85rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* About */
  .sidebar-bio {
    font-size: 0.8rem;
    line-height: 1.55;
    color: var(--color-text);
    margin: 0;
  }
  .sidebar-read-more {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-block-start: auto;
    transition: color var(--transition-fast);
  }
  .sidebar-read-more:hover { color: var(--color-accent); }

  /* Quote */
  .quote-item {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .sidebar-quote-text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.5;
    margin: 0 0 0.5rem;
    color: var(--color-heading);
  }
  .sidebar-quote-text::before {
    content: '\201C';
    font-size: 1.4em;
    color: #8B7355;
    margin-inline-end: 0.1em;
    line-height: 0;
    vertical-align: -0.15em;
  }
  .sidebar-quote-source {
    display: block;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-style: normal;
  }

  /* Currently reading */
  .reading-book {
    display: flex;
    gap: var(--space-sm);
    text-decoration: none;
    color: inherit;
    padding: var(--space-xs) 0;
  }
  .reading-book + .reading-book { border-block-start: 1px solid var(--color-border); }
  .reading-book:hover .reading-title { color: var(--color-accent); }
  .reading-cover { width: 32px; height: auto; border-radius: 2px; flex-shrink: 0; }
  .reading-title {
    display: block;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-heading);
    line-height: 1.3;
    transition: color var(--transition-fast);
  }
  .reading-author { display: block; font-size: 0.68rem; color: var(--color-text-muted); }

  /* Projects */
  .projects-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .project-link {
    font-size: 0.8rem;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.35;
    transition: color var(--transition-fast);
    display: block;
  }
  .project-link:hover { color: var(--color-accent); }
</style>
