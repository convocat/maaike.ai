---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ContentGrid from '../../components/ContentGrid.astro';
import ContentCard from '../../components/ContentCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { sortByDate, getUniqueTags } from '../../utils/collections';
import settings from '../../data/settings.json';
import CollectionIcon from '../../components/CollectionIcon.astro';

const articles = sortByDate(
  (await getCollection('articles')).filter((e) => !e.data.draft)
);
const tags = getUniqueTags(articles);
---

<PageLayout title={`${settings.articlesTitle} — ${settings.siteTitle}`}>
  <h1><CollectionIcon collection="articles" size={28} /> {settings.articlesTitle}</h1>
  <p class="section-description">{settings.articlesDescription}</p>

  <FilterBar tags={tags} />

  <ContentGrid>
    {articles.map((article) => (
      <ContentCard
        title={article.data.title}
        href={`/articles/${article.id}`}
        date={article.data.date}
        updated={article.data.updated}
        maturity={article.data.maturity}
        tags={article.data.tags}
        description={article.data.description}
        collection="articles"
      />
    ))}
  </ContentGrid>
</PageLayout>

<style>
  h1 { display: flex; align-items: center; gap: var(--space-sm); margin-block-end: var(--space-xs); }
  .section-description {
    color: var(--color-text-muted);
    margin-block-end: var(--space-xl);
  }
</style>
