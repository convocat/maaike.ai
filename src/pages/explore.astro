---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SketchyFilter from '../components/SketchyFilter.astro';
---

<BaseLayout title="Explore the garden" description="An interactive map of all content in this digital garden. Browse, wander, or follow curated trails.">
  <SketchyFilter />
  <Header />

  <div id="explore-root">
    <!-- Map container -->
    <div id="map-container">
      <svg id="garden-svg"></svg>
    </div>

    <!-- Page title (top-left) -->
    <div id="explore-title">
      <h1>Explore</h1>
      <p class="explore-subtitle">the garden</p>
    </div>

    <!-- Mode switcher (top-right) -->
    <div id="mode-switcher">
      <button class="mode-btn active" data-mode="map" aria-label="Map view">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
          <circle cx="12" cy="9" r="2.5"/>
        </svg>
        <span>Map</span>
      </button>
      <button class="mode-btn" data-mode="wander" aria-label="Wander mode">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M16.24 7.76l-1.06 5.3-5.3 1.06 1.06-5.3z"/>
          <path d="M12 2v2"/>
          <path d="M12 20v2"/>
          <path d="M2 12h2"/>
          <path d="M20 12h2"/>
        </svg>
        <span>Wander</span>
      </button>
      <button class="mode-btn" data-mode="paths" aria-label="Paths mode">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19c2-2 4-6 8-6s6 4 8 6"/>
          <path d="M4 12c2-2 4-6 8-6s6 4 8 6"/>
          <circle cx="4" cy="19" r="1.5" fill="currentColor"/>
          <circle cx="20" cy="19" r="1.5" fill="currentColor"/>
        </svg>
        <span>Paths</span>
      </button>
    </div>

    <!-- Legend (bottom-left, collapsible) -->
    <div id="legend" class="collapsed">
      <button id="legend-toggle" aria-label="Toggle legend">Legend</button>
      <div id="legend-content">
        <div class="legend-section">
          <h3>Collections</h3>
          <div id="legend-collections"></div>
        </div>
        <div class="legend-section">
          <h3>Maturity</h3>
          <div class="legend-maturity">
            <span class="maturity-item"><span class="maturity-dot" style="width:10px;height:10px;"></span> Draft</span>
            <span class="maturity-item"><span class="maturity-dot" style="width:16px;height:16px;"></span> Developing</span>
            <span class="maturity-item"><span class="maturity-dot" style="width:22px;height:22px;"></span> Solid</span>
            <span class="maturity-item"><span class="maturity-dot" style="width:28px;height:28px;"></span> Complete</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Wander button (bottom-right) -->
    <button id="wander-btn" aria-label="Wander to a random item">
      <canvas id="wander-canvas" width="40" height="40"></canvas>
      <span>Wander</span>
    </button>

    <!-- Wander card (bottom-right, shown when wandering) -->
    <div id="wander-card" class="hidden">
      <div class="wander-card-header">
        <h3 id="wander-title"></h3>
        <button id="wander-close" aria-label="Close wander card">&times;</button>
      </div>
      <p id="wander-collection" class="wander-collection"></p>
      <p id="wander-description"></p>
      <div id="wander-nearby">
        <h4>Nearby</h4>
        <ul id="wander-nearby-list"></ul>
      </div>
      <div class="wander-card-actions">
        <a id="wander-visit" href="#" class="wander-visit-btn">Visit</a>
        <button id="wander-again" class="wander-again-btn">Wander again</button>
      </div>
    </div>

    <!-- Tooltip -->
    <div id="tooltip" class="hidden">
      <div class="tooltip-collection">
        <span class="tooltip-dot"></span>
        <span class="tooltip-collection-name"></span>
      </div>
      <div class="tooltip-title"></div>
      <div class="tooltip-maturity-bar">
        <span class="tooltip-maturity-fill"></span>
      </div>
      <div class="tooltip-description"></div>
    </div>

    <!-- Trail sidebar (left, slides in) -->
    <div id="trail-sidebar" class="hidden">
      <div id="trail-list">
        <h2>Trails</h2>
        <div id="trail-options"></div>
      </div>
      <div id="trail-detail" class="hidden">
        <button id="trail-back" aria-label="Back to trail list">&larr; All trails</button>
        <h3 id="trail-name"></h3>
        <p id="trail-description"></p>
        <div id="trail-progress">
          <div id="trail-progress-bar"></div>
        </div>
        <ol id="trail-steps"></ol>
        <div class="trail-nav">
          <button id="trail-prev" aria-label="Previous step">&larr; Previous</button>
          <button id="trail-next" aria-label="Next step">Next &rarr;</button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ----------------------------------------------------------------
     Explore page layout
     ---------------------------------------------------------------- */
  #explore-root {
    position: relative;
    width: 100%;
    height: calc(100vh - 72px); /* below header */
    overflow: hidden;
    background: var(--color-bg);
  }

  #map-container {
    width: 100%;
    height: 100%;
    cursor: grab;
  }

  #map-container:active {
    cursor: grabbing;
  }

  #garden-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ----------------------------------------------------------------
     Floating UI elements
     ---------------------------------------------------------------- */
  #explore-title {
    position: absolute;
    top: var(--space-lg);
    left: var(--space-lg);
    pointer-events: none;
    z-index: 10;
  }

  #explore-title h1 {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    color: var(--color-heading);
    margin: 0;
    line-height: 1.2;
  }

  .explore-subtitle {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ----------------------------------------------------------------
     Mode switcher
     ---------------------------------------------------------------- */
  #mode-switcher {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    display: flex;
    gap: 2px;
    background: var(--color-border);
    border-radius: var(--card-radius);
    padding: 2px;
    z-index: 10;
  }

  .mode-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: none;
    border-radius: calc(var(--card-radius) - 2px);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }

  .mode-btn:hover {
    background: var(--color-bg);
  }

  .mode-btn.active {
    background: var(--color-accent);
    color: #fff;
  }

  .mode-btn.active:hover {
    background: var(--color-accent);
  }

  .mode-btn svg {
    flex-shrink: 0;
  }

  /* ----------------------------------------------------------------
     Legend
     ---------------------------------------------------------------- */
  #legend {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-lg);
    z-index: 10;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  #legend-toggle {
    display: block;
    width: 100%;
    padding: 8px 16px;
    border: none;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    text-align: left;
  }

  #legend-toggle:hover {
    background: var(--color-bg);
  }

  #legend-content {
    display: none;
    padding: 0 16px 12px;
  }

  #legend:not(.collapsed) #legend-content {
    display: block;
  }

  .legend-section h3 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 8px 0 6px;
  }

  #legend-collections {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .legend-collection-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .legend-color-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .legend-maturity {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .maturity-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text);
  }

  .maturity-dot {
    border-radius: 50%;
    background: var(--color-text-muted);
    opacity: 0.4;
    display: inline-block;
    flex-shrink: 0;
  }

  /* ----------------------------------------------------------------
     Wander button
     ---------------------------------------------------------------- */
  #wander-btn {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-lg);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.875rem;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  #wander-btn:hover {
    border-color: var(--color-accent);
  }

  #wander-canvas {
    display: block;
  }

  /* ----------------------------------------------------------------
     Wander card
     ---------------------------------------------------------------- */
  #wander-card {
    position: absolute;
    bottom: calc(var(--space-lg) + 60px);
    right: var(--space-lg);
    z-index: 15;
    width: 300px;
    max-height: 400px;
    overflow-y: auto;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: 16px;
  }

  .wander-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }

  #wander-card h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--color-heading);
    margin: 0;
    line-height: 1.3;
  }

  #wander-close {
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .wander-collection {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 4px 0 8px;
    text-transform: capitalize;
  }

  #wander-description {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text);
    margin: 0 0 12px;
    line-height: 1.5;
  }

  #wander-nearby h4 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 6px;
  }

  #wander-nearby-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #wander-nearby-list li {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text);
    padding: 3px 0;
  }

  #wander-nearby-list a {
    color: var(--color-accent);
    text-decoration: none;
  }

  #wander-nearby-list a:hover {
    text-decoration: underline;
  }

  .wander-card-actions {
    display: flex;
    gap: 8px;
    margin-top: 12px;
  }

  .wander-visit-btn {
    flex: 1;
    display: block;
    text-align: center;
    padding: 8px 12px;
    border-radius: calc(var(--card-radius) - 2px);
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    text-decoration: none;
    cursor: pointer;
    border: none;
  }

  .wander-again-btn {
    flex: 1;
    padding: 8px 12px;
    border-radius: calc(var(--card-radius) - 2px);
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    border: 1px solid var(--color-border);
    cursor: pointer;
  }

  .wander-again-btn:hover {
    border-color: var(--color-accent);
  }

  /* ----------------------------------------------------------------
     Tooltip
     ---------------------------------------------------------------- */
  #tooltip {
    position: fixed;
    z-index: 100;
    pointer-events: none;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    padding: 12px;
    width: 240px;
    box-shadow: 0 4px 12px var(--color-shadow);
  }

  .tooltip-collection {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 4px;
  }

  .tooltip-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .tooltip-collection-name {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: capitalize;
  }

  .tooltip-title {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    color: var(--color-heading);
    line-height: 1.3;
    margin-bottom: 6px;
  }

  .tooltip-maturity-bar {
    width: 100%;
    height: 3px;
    background: var(--color-border);
    border-radius: 2px;
    margin-bottom: 8px;
    overflow: hidden;
  }

  .tooltip-maturity-fill {
    display: block;
    height: 100%;
    border-radius: 2px;
    background: var(--color-accent);
    transition: width var(--transition-fast);
  }

  .tooltip-description {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ----------------------------------------------------------------
     Trail sidebar
     ---------------------------------------------------------------- */
  #trail-sidebar {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 100%;
    background: var(--color-bg-card);
    border-right: 1px solid var(--color-border);
    z-index: 20;
    overflow-y: auto;
    padding: var(--space-lg);
    transform: translateX(-100%);
    transition: transform var(--transition-base);
  }

  #trail-sidebar:not(.hidden) {
    transform: translateX(0);
  }

  #trail-sidebar h2 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--color-heading);
    margin: 0 0 var(--space-md);
  }

  .trail-option {
    padding: 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--card-radius);
    margin-bottom: 8px;
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .trail-option:hover {
    border-color: var(--color-accent);
  }

  .trail-option h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    color: var(--color-heading);
    margin: 0 0 4px;
  }

  .trail-option p {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
  }

  #trail-back {
    border: none;
    background: transparent;
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    padding: 0;
    margin-bottom: var(--space-md);
  }

  #trail-detail h3 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--color-heading);
    margin: 0 0 6px;
  }

  #trail-description {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-md);
    line-height: 1.4;
  }

  #trail-progress {
    width: 100%;
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    margin-bottom: var(--space-md);
    overflow: hidden;
  }

  #trail-progress-bar {
    height: 100%;
    background: var(--color-accent);
    border-radius: 2px;
    transition: width var(--transition-base);
  }

  #trail-steps {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-md);
  }

  #trail-steps li {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text);
    padding: 8px 10px;
    border-radius: calc(var(--card-radius) - 2px);
    cursor: pointer;
    transition: background var(--transition-fast);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #trail-steps li:hover {
    background: var(--color-bg);
  }

  #trail-steps li.active {
    background: var(--color-accent);
    color: #fff;
  }

  #trail-steps .step-number {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-border);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  #trail-steps li.active .step-number {
    background: rgba(255,255,255,0.2);
    color: #fff;
  }

  .trail-nav {
    display: flex;
    gap: 8px;
  }

  .trail-nav button {
    flex: 1;
    padding: 8px 12px;
    border-radius: calc(var(--card-radius) - 2px);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    cursor: pointer;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color var(--transition-fast);
  }

  .trail-nav button:hover {
    border-color: var(--color-accent);
  }

  .trail-nav button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  /* ----------------------------------------------------------------
     Utility
     ---------------------------------------------------------------- */
  .hidden {
    display: none !important;
  }

  /* SVG item circles */
  .item-circle {
    cursor: pointer;
    transition: opacity 150ms ease;
  }

  /* ----------------------------------------------------------------
     Responsive
     ---------------------------------------------------------------- */
  @media (max-width: 640px) {
    #explore-title h1 {
      font-size: 1.25rem;
    }

    .mode-btn span {
      display: none;
    }

    .mode-btn {
      padding: 8px 10px;
    }

    #trail-sidebar {
      width: 100%;
    }

    #wander-card {
      width: calc(100% - 2 * var(--space-lg));
      right: var(--space-lg);
      left: var(--space-lg);
    }
  }
</style>

<script is:inline>
(function() {
  'use strict';

  // ----------------------------------------------------------------
  // Constants
  // ----------------------------------------------------------------

  const COLLECTION_COLORS = {
    articles:       { light: '#9e7c6b', dark: '#c4a38f' },
    'field-notes':  { light: '#7a9a7e', dark: '#a3c4a7' },
    seeds:          { light: '#c4956a', dark: '#ddb892' },
    weblinks:       { light: '#a08872', dark: '#c4ad98' },
    videos:         { light: '#8e7a8a', dark: '#b5a3b2' },
    library:        { light: '#7d7068', dark: '#a89e96' },
    experiments:    { light: '#6a8e96', dark: '#92b8c0' },
    principles:     { light: '#7a8a6e', dark: '#a3b498' },
  };

  const MATURITY_RADIUS = { draft: 5, developing: 8, solid: 11, complete: 14 };
  const MATURITY_PROGRESS = { draft: 0.25, developing: 0.5, solid: 0.75, complete: 1.0 };

  const COLLECTION_LABELS = {
    articles: 'Articles',
    'field-notes': 'Field notes',
    seeds: 'Seeds',
    weblinks: 'Weblinks',
    videos: 'Videos',
    library: 'Library',
    experiments: 'Experiments',
    principles: 'Principles',
  };

  // ----------------------------------------------------------------
  // State
  // ----------------------------------------------------------------

  let data = null;          // { items, clusters, trails }
  let currentMode = 'map';  // 'map' | 'wander' | 'paths'
  let activeTrail = null;
  let activeTrailStep = 0;
  let wanderItem = null;
  let svgWidth = 0;
  let svgHeight = 0;
  let roughSvg = null;
  let currentTransform = null;
  let zoomBehavior = null;

  // ----------------------------------------------------------------
  // DOM references
  // ----------------------------------------------------------------

  const svg = document.getElementById('garden-svg');
  const tooltip = document.getElementById('tooltip');
  const wanderCard = document.getElementById('wander-card');
  const trailSidebar = document.getElementById('trail-sidebar');

  // ----------------------------------------------------------------
  // Helpers
  // ----------------------------------------------------------------

  function isDark() {
    return document.documentElement.getAttribute('data-theme') === 'dark';
  }

  function getCollectionColor(collection, opacity) {
    const mode = isDark() ? 'dark' : 'light';
    const hex = (COLLECTION_COLORS[collection] || COLLECTION_COLORS.articles)[mode];
    if (opacity === undefined) return hex;
    // hex to rgba
    const r = parseInt(hex.slice(1,3), 16);
    const g = parseInt(hex.slice(3,5), 16);
    const b = parseInt(hex.slice(5,7), 16);
    return `rgba(${r},${g},${b},${opacity})`;
  }

  function getAccentColor() {
    return isDark() ? '#FF4DA6' : '#D6006C';
  }

  function toSVGX(normalizedX) { return normalizedX * svgWidth; }
  function toSVGY(normalizedY) { return normalizedY * svgHeight; }

  function distance(a, b) {
    const dx = a.x - b.x;
    const dy = a.y - b.y;
    return Math.sqrt(dx * dx + dy * dy);
  }

  function findNearbyItems(item, count) {
    return data.items
      .filter(i => i.slug !== item.slug)
      .map(i => ({ ...i, dist: distance(item, i) }))
      .sort((a, b) => a.dist - b.dist)
      .slice(0, count);
  }

  // ----------------------------------------------------------------
  // Initialize
  // ----------------------------------------------------------------

  async function init() {
    try {
      const resp = await fetch('/explore-data.json');
      data = await resp.json();
    } catch (e) {
      console.error('Failed to load explore data:', e);
      return;
    }

    updateDimensions();
    buildLegend();
    setupModeButtons();
    setupWanderButton();
    setupTrailSidebar();
    drawMap();
    setupZoom();
    setupThemeObserver();
    window.addEventListener('resize', onResize);
  }

  function updateDimensions() {
    const rect = svg.parentElement.getBoundingClientRect();
    svgWidth = rect.width;
    svgHeight = rect.height;
    svg.setAttribute('viewBox', `0 0 ${svgWidth} ${svgHeight}`);
  }

  function onResize() {
    updateDimensions();
    redraw();
  }

  // ----------------------------------------------------------------
  // Theme observer: redraw when dark mode toggles
  // ----------------------------------------------------------------

  function setupThemeObserver() {
    const observer = new MutationObserver(mutations => {
      for (const m of mutations) {
        if (m.attributeName === 'data-theme') {
          redraw();
          drawWanderSignpost();
        }
      }
    });
    observer.observe(document.documentElement, { attributes: true });
  }

  // ----------------------------------------------------------------
  // Legend
  // ----------------------------------------------------------------

  function buildLegend() {
    const container = document.getElementById('legend-collections');
    for (const [key, label] of Object.entries(COLLECTION_LABELS)) {
      const el = document.createElement('div');
      el.className = 'legend-collection-item';
      el.innerHTML = `<span class="legend-color-dot" style="background:${getCollectionColor(key)}"></span>${label}`;
      container.appendChild(el);
    }

    document.getElementById('legend-toggle').addEventListener('click', () => {
      document.getElementById('legend').classList.toggle('collapsed');
    });
  }

  // ----------------------------------------------------------------
  // Mode buttons
  // ----------------------------------------------------------------

  function setupModeButtons() {
    const buttons = document.querySelectorAll('.mode-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode;
        if (mode === currentMode) return;
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentMode = mode;
        onModeChange();
      });
    });
  }

  function onModeChange() {
    // Reset state
    hideWanderCard();
    wanderItem = null;
    activeTrail = null;

    if (currentMode === 'paths') {
      trailSidebar.classList.remove('hidden');
      document.getElementById('trail-list').classList.remove('hidden');
      document.getElementById('trail-detail').classList.add('hidden');
    } else {
      trailSidebar.classList.add('hidden');
    }

    if (currentMode === 'wander') {
      document.getElementById('wander-btn').style.display = '';
    } else {
      document.getElementById('wander-btn').style.display = '';
    }

    redraw();
  }

  // ----------------------------------------------------------------
  // Drawing
  // ----------------------------------------------------------------

  function redraw() {
    clearOverlays();
    drawMap();
    if (currentMode === 'wander' && wanderItem) {
      drawWanderHighlight(wanderItem);
    }
    if (currentMode === 'paths' && activeTrail) {
      drawTrailPath(activeTrail);
    }
  }

  function clearOverlays() {
    // Remove rough.js overlays
    svg.querySelectorAll('.rough-overlay, .cluster-label').forEach(el => el.remove());
  }

  function drawMap() {
    // Remove existing item group
    let itemGroup = svg.querySelector('#items-group');
    if (itemGroup) itemGroup.remove();
    let clusterGroup = svg.querySelector('#cluster-group');
    if (clusterGroup) clusterGroup.remove();

    // Create rough.js SVG instance
    if (typeof roughjs !== 'undefined' || typeof rough !== 'undefined') {
      const roughLib = typeof rough !== 'undefined' ? rough : roughjs;
      roughSvg = roughLib.svg(svg);
    }

    // Draw clusters
    clusterGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    clusterGroup.id = 'cluster-group';
    if (currentTransform) {
      clusterGroup.setAttribute('transform', `translate(${currentTransform.x},${currentTransform.y}) scale(${currentTransform.k})`);
    }
    svg.appendChild(clusterGroup);

    if (roughSvg && data.clusters) {
      for (const cluster of data.clusters) {
        const cx = toSVGX(cluster.centerX);
        const cy = toSVGY(cluster.centerY);
        const rx = cluster.radius * svgWidth * 0.5;
        const ry = cluster.radius * svgHeight * 0.5;
        const clusterColor = isDark() ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.04)';

        const ellipse = roughSvg.ellipse(cx, cy, rx * 2, ry * 2, {
          stroke: clusterColor,
          strokeWidth: 0.5,
          fill: clusterColor,
          fillStyle: 'solid',
          roughness: 2,
        });
        ellipse.classList.add('rough-overlay');
        clusterGroup.appendChild(ellipse);

        // Cluster label
        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('x', cx);
        label.setAttribute('y', cy - ry * 0.7);
        label.setAttribute('text-anchor', 'middle');
        label.setAttribute('fill', isDark() ? 'rgba(255,255,255,0.2)' : 'rgba(0,0,0,0.15)');
        label.setAttribute('font-family', 'Lora, Georgia, serif');
        label.setAttribute('font-size', '13');
        label.setAttribute('font-style', 'italic');
        label.textContent = cluster.label;
        label.classList.add('cluster-label');
        clusterGroup.appendChild(label);
      }
    }

    // Draw items
    itemGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    itemGroup.id = 'items-group';
    if (currentTransform) {
      itemGroup.setAttribute('transform', `translate(${currentTransform.x},${currentTransform.y}) scale(${currentTransform.k})`);
    }
    svg.appendChild(itemGroup);

    for (const item of data.items) {
      const cx = toSVGX(item.x);
      const cy = toSVGY(item.y);
      const r = MATURITY_RADIUS[item.maturity] || 5;
      const color = getCollectionColor(item.collection, 0.6);

      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', cx);
      circle.setAttribute('cy', cy);
      circle.setAttribute('r', r);
      circle.setAttribute('fill', color);
      circle.setAttribute('data-slug', item.slug);
      circle.classList.add('item-circle');

      // Hover
      circle.addEventListener('mouseenter', e => onItemHover(e, item, circle));
      circle.addEventListener('mousemove', e => moveTooltip(e));
      circle.addEventListener('mouseleave', () => onItemLeave(circle));
      circle.addEventListener('click', () => {
        window.location.href = item.url;
      });

      itemGroup.appendChild(circle);
    }
  }

  // ----------------------------------------------------------------
  // Zoom (d3)
  // ----------------------------------------------------------------

  function setupZoom() {
    // Wait for d3 to load
    if (typeof d3 === 'undefined') {
      // Try again shortly
      setTimeout(setupZoom, 100);
      return;
    }

    zoomBehavior = d3.zoom()
      .scaleExtent([0.3, 5])
      .on('zoom', event => {
        currentTransform = event.transform;
        const itemGroup = svg.querySelector('#items-group');
        const clusterGroup = svg.querySelector('#cluster-group');
        const t = `translate(${event.transform.x},${event.transform.y}) scale(${event.transform.k})`;
        if (itemGroup) itemGroup.setAttribute('transform', t);
        if (clusterGroup) clusterGroup.setAttribute('transform', t);
        // Also transform any rough overlays
        svg.querySelectorAll('.wander-overlay, .trail-overlay').forEach(g => {
          g.setAttribute('transform', t);
        });
      });

    d3.select(svg).call(zoomBehavior);
  }

  function panTo(item, duration) {
    if (!zoomBehavior || typeof d3 === 'undefined') return;

    const x = toSVGX(item.x);
    const y = toSVGY(item.y);
    const scale = 2;

    const transform = d3.zoomIdentity
      .translate(svgWidth / 2 - x * scale, svgHeight / 2 - y * scale)
      .scale(scale);

    d3.select(svg)
      .transition()
      .duration(duration || 750)
      .call(zoomBehavior.transform, transform);
  }

  // ----------------------------------------------------------------
  // Tooltip
  // ----------------------------------------------------------------

  function onItemHover(e, item, circle) {
    const r = parseFloat(circle.getAttribute('r'));
    circle.setAttribute('r', r * 1.2);
    circle.setAttribute('fill', getCollectionColor(item.collection, 0.85));

    // Show dashed pink ring
    const cx = parseFloat(circle.getAttribute('cx'));
    const cy = parseFloat(circle.getAttribute('cy'));
    const ring = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    ring.setAttribute('cx', cx);
    ring.setAttribute('cy', cy);
    ring.setAttribute('r', r + 6);
    ring.setAttribute('fill', 'none');
    ring.setAttribute('stroke', getAccentColor());
    ring.setAttribute('stroke-width', '1.5');
    ring.setAttribute('stroke-dasharray', '3 3');
    ring.classList.add('hover-ring');
    circle.parentNode.appendChild(ring);

    // Populate tooltip
    tooltip.querySelector('.tooltip-dot').style.background = getCollectionColor(item.collection);
    tooltip.querySelector('.tooltip-collection-name').textContent = COLLECTION_LABELS[item.collection] || item.collection;
    tooltip.querySelector('.tooltip-title').textContent = item.title;
    tooltip.querySelector('.tooltip-maturity-fill').style.width = (MATURITY_PROGRESS[item.maturity] * 100) + '%';
    tooltip.querySelector('.tooltip-description').textContent = item.description || '';
    tooltip.classList.remove('hidden');

    moveTooltip(e);
  }

  function moveTooltip(e) {
    const pad = 16;
    let x = e.clientX + pad;
    let y = e.clientY + pad;

    // Keep on screen
    const tw = 240;
    const th = tooltip.offsetHeight || 120;
    if (x + tw > window.innerWidth) x = e.clientX - tw - pad;
    if (y + th > window.innerHeight) y = e.clientY - th - pad;

    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  }

  function onItemLeave(circle) {
    const slug = circle.getAttribute('data-slug');
    const item = data.items.find(i => i.slug === slug);
    const r = MATURITY_RADIUS[item ? item.maturity : 'draft'] || 5;
    circle.setAttribute('r', r);
    circle.setAttribute('fill', getCollectionColor(item ? item.collection : 'articles', 0.6));

    // Remove hover ring
    circle.parentNode.querySelectorAll('.hover-ring').forEach(el => el.remove());

    tooltip.classList.add('hidden');
  }

  // ----------------------------------------------------------------
  // Wander
  // ----------------------------------------------------------------

  function setupWanderButton() {
    drawWanderSignpost();

    document.getElementById('wander-btn').addEventListener('click', doWander);
    document.getElementById('wander-again').addEventListener('click', doWander);
    document.getElementById('wander-close').addEventListener('click', () => {
      hideWanderCard();
      wanderItem = null;
      redraw();
    });
  }

  function drawWanderSignpost() {
    const canvas = document.getElementById('wander-canvas');
    if (!canvas || typeof rough === 'undefined') return;
    const rc = rough.canvas(canvas);
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, 40, 40);
    const stroke = isDark() ? '#E8E8E8' : '#1A1A1A';
    // Simple signpost
    rc.line(20, 8, 20, 36, { stroke, strokeWidth: 1.2, roughness: 1.2 });
    rc.rectangle(8, 10, 24, 8, { stroke, strokeWidth: 1, roughness: 1.5, fill: getCollectionColor('field-notes', 0.3), fillStyle: 'solid' });
    rc.rectangle(12, 20, 20, 7, { stroke, strokeWidth: 1, roughness: 1.5, fill: getCollectionColor('seeds', 0.3), fillStyle: 'solid' });
  }

  function doWander() {
    if (!data) return;
    // Pick random item
    const idx = Math.floor(Math.random() * data.items.length);
    wanderItem = data.items[idx];

    // Switch to wander mode if not already
    if (currentMode !== 'wander') {
      currentMode = 'wander';
      document.querySelectorAll('.mode-btn').forEach(b => {
        b.classList.toggle('active', b.dataset.mode === 'wander');
      });
      trailSidebar.classList.add('hidden');
    }

    // Pan to item
    panTo(wanderItem, 800);

    // Show wander highlight after pan
    setTimeout(() => {
      redraw();
      showWanderCard(wanderItem);
    }, 850);
  }

  function drawWanderHighlight(item) {
    if (!roughSvg) return;

    let group = svg.querySelector('.wander-overlay');
    if (group) group.remove();

    group = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    group.classList.add('wander-overlay');
    if (currentTransform) {
      group.setAttribute('transform', `translate(${currentTransform.x},${currentTransform.y}) scale(${currentTransform.k})`);
    }
    svg.appendChild(group);

    const cx = toSVGX(item.x);
    const cy = toSVGY(item.y);
    const accent = getAccentColor();

    // Rough circle around item
    const highlight = roughSvg.circle(cx, cy, 60, {
      stroke: accent,
      strokeWidth: 1.5,
      fill: 'none',
      roughness: 2.5,
    });
    group.appendChild(highlight);

    // Lines to nearby items
    const nearby = findNearbyItems(item, 4);
    for (const n of nearby) {
      const nx = toSVGX(n.x);
      const ny = toSVGY(n.y);
      const line = roughSvg.line(cx, cy, nx, ny, {
        stroke: isDark() ? 'rgba(255,255,255,0.15)' : 'rgba(0,0,0,0.1)',
        strokeWidth: 0.8,
        roughness: 1.5,
      });
      group.appendChild(line);
    }
  }

  function showWanderCard(item) {
    document.getElementById('wander-title').textContent = item.title;
    document.getElementById('wander-collection').textContent = (COLLECTION_LABELS[item.collection] || item.collection) + ' · ' + item.maturity;
    document.getElementById('wander-description').textContent = item.description || '';
    document.getElementById('wander-visit').href = item.url;

    // Nearby items
    const list = document.getElementById('wander-nearby-list');
    list.innerHTML = '';
    const nearby = findNearbyItems(item, 4);
    for (const n of nearby) {
      const li = document.createElement('li');
      li.innerHTML = `<a href="${n.url}">${n.title}</a>`;
      list.appendChild(li);
    }

    wanderCard.classList.remove('hidden');
  }

  function hideWanderCard() {
    wanderCard.classList.add('hidden');
  }

  // ----------------------------------------------------------------
  // Trails
  // ----------------------------------------------------------------

  function setupTrailSidebar() {
    // Will be populated after data loads
    // Use a deferred call
    const origInit = init;
    const optionsEl = document.getElementById('trail-options');

    // Build trail options after data is ready
    const buildTrailOptions = () => {
      if (!data) return;
      optionsEl.innerHTML = '';
      for (const trail of data.trails) {
        const div = document.createElement('div');
        div.className = 'trail-option';
        div.innerHTML = `<h3>${trail.name}</h3><p>${trail.description}</p>`;
        div.addEventListener('click', () => selectTrail(trail));
        optionsEl.appendChild(div);
      }
    };

    // Observe data load
    const checkData = setInterval(() => {
      if (data) {
        buildTrailOptions();
        clearInterval(checkData);
      }
    }, 100);

    document.getElementById('trail-back').addEventListener('click', () => {
      activeTrail = null;
      document.getElementById('trail-list').classList.remove('hidden');
      document.getElementById('trail-detail').classList.add('hidden');
      redraw();
    });

    document.getElementById('trail-prev').addEventListener('click', () => {
      if (activeTrailStep > 0) {
        activeTrailStep--;
        updateTrailStep();
      }
    });

    document.getElementById('trail-next').addEventListener('click', () => {
      if (activeTrail && activeTrailStep < activeTrail.items.length - 1) {
        activeTrailStep++;
        updateTrailStep();
      }
    });
  }

  function selectTrail(trail) {
    activeTrail = trail;
    activeTrailStep = 0;

    document.getElementById('trail-list').classList.add('hidden');
    document.getElementById('trail-detail').classList.remove('hidden');
    document.getElementById('trail-name').textContent = trail.name;
    document.getElementById('trail-description').textContent = trail.description;

    buildTrailSteps(trail);
    updateTrailStep();
    drawTrailPath(trail);
  }

  function buildTrailSteps(trail) {
    const ol = document.getElementById('trail-steps');
    ol.innerHTML = '';
    trail.items.forEach((slug, i) => {
      const item = data.items.find(d => d.slug === slug);
      const li = document.createElement('li');
      li.innerHTML = `<span class="step-number">${i + 1}</span><span>${item ? item.title : slug}</span>`;
      li.addEventListener('click', () => {
        activeTrailStep = i;
        updateTrailStep();
      });
      ol.appendChild(li);
    });
  }

  function updateTrailStep() {
    if (!activeTrail) return;

    // Update step highlighting
    const steps = document.querySelectorAll('#trail-steps li');
    steps.forEach((li, i) => {
      li.classList.toggle('active', i === activeTrailStep);
    });

    // Update progress bar
    const progress = ((activeTrailStep + 1) / activeTrail.items.length) * 100;
    document.getElementById('trail-progress-bar').style.width = progress + '%';

    // Update prev/next buttons
    document.getElementById('trail-prev').disabled = activeTrailStep === 0;
    document.getElementById('trail-next').disabled = activeTrailStep === activeTrail.items.length - 1;

    // Pan to current step item
    const slug = activeTrail.items[activeTrailStep];
    const item = data.items.find(d => d.slug === slug);
    if (item) panTo(item, 600);
  }

  function drawTrailPath(trail) {
    if (!roughSvg) return;

    let group = svg.querySelector('.trail-overlay');
    if (group) group.remove();

    group = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    group.classList.add('trail-overlay');
    if (currentTransform) {
      group.setAttribute('transform', `translate(${currentTransform.x},${currentTransform.y}) scale(${currentTransform.k})`);
    }
    // Insert before items so path is behind circles
    const itemGroup = svg.querySelector('#items-group');
    svg.insertBefore(group, itemGroup);

    const accent = getAccentColor();
    const trailItems = trail.items
      .map(slug => data.items.find(d => d.slug === slug))
      .filter(Boolean);

    // Draw path segments
    for (let i = 0; i < trailItems.length - 1; i++) {
      const a = trailItems[i];
      const b = trailItems[i + 1];
      const line = roughSvg.line(
        toSVGX(a.x), toSVGY(a.y),
        toSVGX(b.x), toSVGY(b.y),
        {
          stroke: accent,
          strokeWidth: 1.5,
          roughness: 2,
        }
      );
      group.appendChild(line);
    }

    // Draw circles at each trail stop
    for (let i = 0; i < trailItems.length; i++) {
      const item = trailItems[i];
      const isActive = i === activeTrailStep;
      const circle = roughSvg.circle(
        toSVGX(item.x), toSVGY(item.y),
        isActive ? 40 : 28,
        {
          stroke: accent,
          strokeWidth: isActive ? 2 : 1,
          fill: isActive ? accent : 'none',
          fillStyle: 'solid',
          fillWeight: 0.5,
          roughness: 2,
        }
      );
      group.appendChild(circle);

      // Step number label
      const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      label.setAttribute('x', toSVGX(item.x));
      label.setAttribute('y', toSVGY(item.y) + 4);
      label.setAttribute('text-anchor', 'middle');
      label.setAttribute('fill', isActive ? '#fff' : accent);
      label.setAttribute('font-family', 'Lora, Georgia, serif');
      label.setAttribute('font-size', '11');
      label.setAttribute('font-weight', '600');
      label.textContent = i + 1;
      group.appendChild(label);
    }
  }

  // ----------------------------------------------------------------
  // Load d3 and rough.js from CDN, then init
  // ----------------------------------------------------------------

  function loadScript(src) {
    return new Promise((resolve, reject) => {
      // For ES module imports
      if (src.includes('+esm')) {
        import(src).then(module => {
          window.d3 = module;
          resolve();
        }).catch(reject);
        return;
      }
      const s = document.createElement('script');
      s.src = src;
      s.onload = resolve;
      s.onerror = reject;
      document.head.appendChild(s);
    });
  }

  async function boot() {
    try {
      await Promise.all([
        loadScript('https://cdn.jsdelivr.net/npm/roughjs@4.6.6/bundled/rough.min.js'),
        loadScript('https://cdn.jsdelivr.net/npm/d3@7/+esm'),
      ]);
    } catch (e) {
      console.warn('CDN script load failed, continuing without rough.js / d3:', e);
    }
    init();
  }

  // Run on DOMContentLoaded or immediately if already loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
})();
</script>
