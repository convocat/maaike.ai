---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ContentGrid from '../../components/ContentGrid.astro';
import ContentCard from '../../components/ContentCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { sortByDate, getUniqueTags } from '../../utils/collections';
import settings from '../../data/settings.json';
import CollectionIcon from '../../components/CollectionIcon.astro';

const weblinks = sortByDate(
  (await getCollection('weblinks')).filter((e) => !e.data.draft && e.data.maturity !== 'compost')
);
const tags = getUniqueTags(weblinks);
---

<PageLayout title={`${settings.weblinksTitle} — ${settings.siteTitle}`}>
  <h1><CollectionIcon collection="weblinks" size={28} /> {settings.weblinksTitle}</h1>
  <p class="section-description">{settings.weblinksDescription}</p>

  <FilterBar tags={tags} />

  <ContentGrid>
    {weblinks.map((link) => (
      <ContentCard
        title={link.data.title}
        href={`/weblinks/${link.id}`}
        date={link.data.date}
        maturity={link.data.maturity}
        tags={link.data.tags}
        description={link.data.description}
        collection="weblinks"
      />
    ))}
  </ContentGrid>
</PageLayout>

<style>
  h1 { display: flex; align-items: center; gap: var(--space-sm); margin-block-end: var(--space-xs); }
  .section-description {
    color: var(--color-text-muted);
    margin-block-end: var(--space-xl);
  }
</style>
