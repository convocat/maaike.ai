---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ContentGrid from '../../components/ContentGrid.astro';
import ContentCard from '../../components/ContentCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { sortByDate, getUniqueTags } from '../../utils/collections';
import settings from '../../data/settings.json';
import CollectionIcon from '../../components/CollectionIcon.astro';

const fieldNotes = sortByDate(
  (await getCollection('fieldNotes')).filter((e) => !e.data.draft && e.data.maturity !== 'compost')
);
const tags = getUniqueTags(fieldNotes);
---

<PageLayout title={`${settings.fieldNotesTitle} — ${settings.siteTitle}`}>
  <h1><CollectionIcon collection="field-notes" size={28} /> {settings.fieldNotesTitle}</h1>
  <p class="section-description">{settings.fieldNotesDescription}</p>

  <FilterBar tags={tags} />

  <ContentGrid>
    {fieldNotes.map((note) => (
      <ContentCard
        title={note.data.title}
        href={`/field-notes/${note.id}`}
        date={note.data.date}
        updated={note.data.updated}
        maturity={note.data.maturity}
        tags={note.data.tags}
        description={note.data.description}
        collection="field-notes"
      />
    ))}
  </ContentGrid>
</PageLayout>

<style>
  h1 { display: flex; align-items: center; gap: var(--space-sm); margin-block-end: var(--space-xs); }
  .section-description {
    color: var(--color-text-muted);
    margin-block-end: var(--space-xl);
  }
</style>
