---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ContentGrid from '../../components/ContentGrid.astro';
import ContentCard from '../../components/ContentCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { sortByDate, getUniqueTags } from '../../utils/collections';
import settings from '../../data/settings.json';

const links = sortByDate(
  (await getCollection('links')).filter((e) => !e.data.draft)
);
const tags = getUniqueTags(links);
---

<PageLayout title={`${settings.linksTitle} — ${settings.siteTitle}`}>
  <h1>{settings.linksTitle}</h1>
  <p class="section-description">{settings.linksDescription}</p>

  <FilterBar tags={tags} />

  <ContentGrid>
    {links.map((link) => (
      <ContentCard
        title={link.data.title}
        href={`/links/${link.id}`}
        date={link.data.date}
        maturity={link.data.maturity}
        tags={link.data.tags}
        description={link.data.description}
        collection="links"
      />
    ))}
  </ContentGrid>
</PageLayout>

<style>
  h1 { margin-block-end: var(--space-xs); }
  .section-description {
    color: var(--color-text-muted);
    margin-block-end: var(--space-xl);
  }
</style>
