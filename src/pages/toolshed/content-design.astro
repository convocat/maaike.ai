---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import settings from '../../data/settings.json';

const allPosts = (await getCollection('toolshed'))
  .filter((e: any) => !e.data.draft && e.data.category === 'content')
  .sort((a: any, b: any) => a.data.title.localeCompare(b.data.title));

// Section order and labels
const sectionOrder = [
  { key: 'Concept',      desc: 'What the garden is and why it exists' },
  { key: 'Voice',        desc: 'How to write for the garden' },
  { key: 'Patterns',     desc: 'Structural content patterns and prose conventions' },
  { key: 'Transparency', desc: 'AI attribution, maturity, editorial honesty' },
  { key: 'Publishing',   desc: 'From draft to live: the publishing workflow' },
];

// Group posts by section
const grouped: Record<string, typeof allPosts> = {};
for (const post of allPosts) {
  const sec = (post.data as any).section ?? 'Unsectioned';
  if (!grouped[sec]) grouped[sec] = [];
  grouped[sec].push(post);
}

// Sections that have posts, in defined order first, then any stragglers
const orderedSections = [
  ...sectionOrder.filter(s => grouped[s.key]?.length),
  ...Object.keys(grouped)
    .filter(k => !sectionOrder.find(s => s.key === k))
    .map(k => ({ key: k, desc: '' })),
];
---

<PageLayout title={`Content design — Toolshed — ${settings.siteTitle}`} description="The garden metaphor, editorial voice, prose patterns, and content conventions behind this garden.">

  <div class="ds-heading">
    <a href="/toolshed" class="ds-back">&larr; Toolshed</a>
    <h1>Content design</h1>
    <p class="ds-desc">The garden as a concept, the voice behind the writing, and the patterns that give content its shape.</p>
  </div>

  {allPosts.length === 0 ? (
    <p class="ds-empty">No content design documents yet.</p>
  ) : (
    <div class="ds-body">
      {orderedSections.map(sec => (
        <section class="ds-section">
          <div class="ds-section-header">
            <h2 class="ds-section-title">{sec.key}</h2>
            {sec.desc && <p class="ds-section-desc">{sec.desc}</p>}
          </div>
          <ul class="ds-post-list">
            {grouped[sec.key].map((post: any) => (
              <li class="ds-post-item">
                <a href={`/toolshed/${post.id}`} class="ds-post-link">
                  <div class="ds-post-strip"></div>
                  <div class="ds-post-main">
                    <span class="ds-post-title">{post.data.title}</span>
                    {post.data.description && (
                      <span class="ds-post-desc">{post.data.description}</span>
                    )}
                  </div>
                  <div class="ds-post-meta">
                    <span class="ds-maturity" title={post.data.maturity}>
                      {post.data.maturity === 'draft' ? '🌱'
                        : post.data.maturity === 'developing' ? '🌿'
                        : post.data.maturity === 'solid' ? '🪴'
                        : '🌳'}
                    </span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}

</PageLayout>

<style>
  .ds-heading {
    margin-bottom: var(--space-2xl);
  }

  .ds-back {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: color 0.15s;
  }
  .ds-back:hover { color: var(--color-accent); }

  .ds-heading h1 {
    font-size: 2rem;
    margin-bottom: var(--space-xs);
  }

  .ds-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    max-width: 52ch;
  }

  .ds-empty {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 0.9rem;
  }

  .ds-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .ds-section-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--color-accent);
  }

  .ds-section-title {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin: 0;
  }

  .ds-section-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .ds-post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ds-post-item {
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
  }
  :root[data-theme="dark"] .ds-post-item { background: var(--color-bg-card); }
  .ds-post-item:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(0,0,0,0.08);
    border-color: transparent;
  }

  .ds-post-link {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    text-decoration: none;
    min-height: 3.5rem;
  }

  .ds-post-strip {
    width: 10px;
    flex-shrink: 0;
    background: #E8E2D8;
    border-inline-end: 2px double rgba(120, 90, 60, 0.2);
  }
  :root[data-theme="dark"] .ds-post-strip { background: #2a2620; }

  .ds-post-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
    padding: 0.6rem 1rem;
    min-width: 0;
  }

  .ds-post-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.3;
    transition: color 0.15s;
  }
  .ds-post-item:hover .ds-post-title { color: var(--color-accent); }

  .ds-post-desc {
    font-size: 0.76rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .ds-post-meta {
    display: flex;
    align-items: center;
    padding: 0 var(--space-md);
    flex-shrink: 0;
  }

  .ds-maturity {
    font-size: 1rem;
    opacity: 0.6;
  }
  .ds-post-item:hover .ds-maturity { opacity: 1; }
</style>
