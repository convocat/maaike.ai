---
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SketchyFilter from '../../components/SketchyFilter.astro';
import settings from '../../data/settings.json';

// ── Backlog parser ──────────────────────────────────────────────────────────

interface BacklogItem {
  status: string;
  title: string;
  meta: string;
  body: string;
  bodyFull: string;
}

function parseBacklog(content: string): {
  ready: BacklogItem[];
  inProgress: BacklogItem[];
  parked: BacklogItem[];
  done: BacklogItem[];
} {
  const archiveIdx = content.indexOf('\n## Archive');
  const main    = archiveIdx > 0 ? content.slice(0, archiveIdx) : content;
  const archive = archiveIdx > 0 ? content.slice(archiveIdx)    : '';

  function extractItems(src: string, doneMode = false): BacklogItem[] {
    const items: BacklogItem[] = [];
    const splitPattern = doneMode ? /(?=\n### )/ : /(?=\n## )/;
    const headingPrefix = doneMode ? '### ' : '## ';
    const prefixLen = headingPrefix.length;
    const chunks = src.split(splitPattern);
    for (const chunk of chunks) {
      const trimmed = chunk.trim();
      if (!trimmed.startsWith(headingPrefix)) continue;
      const firstNewline = trimmed.indexOf('\n');
      const heading = firstNewline > 0 ? trimmed.slice(prefixLen, firstNewline).trim() : trimmed.slice(prefixLen).trim();
      const rest    = firstNewline > 0 ? trimmed.slice(firstNewline + 1) : '';

      let status = '';
      let title  = heading;
      if      (heading.startsWith('🟡')) { status = 'ready';       title = heading.slice(2).trim(); }
      else if (heading.startsWith('🔵')) { status = 'in-progress'; title = heading.slice(2).trim(); }
      else if (heading.startsWith('🟠')) { status = 'parked';      title = heading.slice(2).trim(); }
      else if (doneMode && heading.startsWith('✅')) { status = 'done'; title = heading.replace(/^✅\s*/, '').trim(); }
      else if (doneMode)                 { status = 'done';         title = heading; }
      else continue;

      const lines    = rest.split('\n');
      const metaLine = lines.find(l => /^\*[^*]/.test(l.trim()) && /\*$/.test(l.trim())) ?? '';
      const meta     = metaLine.replace(/^\*/, '').replace(/\*$/, '').trim();
      const bodyLines = lines.filter(l => l.trim() !== metaLine.trim() && l.trim() !== '---');
      const bodyFull  = bodyLines.join('\n').trim();
      const body      = bodyFull.slice(0, 200);

      items.push({ status, title, meta, body, bodyFull });
    }
    return items;
  }

  const activeItems = extractItems(main);
  const doneItems   = extractItems(archive, true)
    .filter(i => i.status === 'done')
    .slice(0, 8);

  return {
    ready:      activeItems.filter(i => i.status === 'ready'),
    inProgress: activeItems.filter(i => i.status === 'in-progress'),
    parked:     activeItems.filter(i => i.status === 'parked'),
    done:       doneItems,
  };
}

const backlogRaw = fs.readFileSync(path.join(process.cwd(), '.claude', 'backlog.md'), 'utf-8');
const backlog    = parseBacklog(backlogRaw);

// ── Garden health ───────────────────────────────────────────────────────────

const healthRaw       = fs.readFileSync(path.join(process.cwd(), '.claude', 'health-report.md'), 'utf-8');
const healthDate      = healthRaw.match(/Date: (\d{4}-\d{2}-\d{2})/)?.[1] ?? 'unknown';
const brokenLinkCount = parseInt(healthRaw.match(/\*\*(\d+) real broken link/)?.[1] ?? '0');
const tagTableRows    = (healthRaw.match(/\| `[a-z]/g) || []).length;
const missingDescCount = parseInt(healthRaw.match(/(\d+) files in `src\/content\/library\/` are missing/)?.[1] ?? '0');

// ── Release notes ───────────────────────────────────────────────────────────

interface ChangelogEntry {
  isoDate: string;
  displayDate: string;
  monthKey: string;
  monthLabel: string;
  intro: string;
  bullets: { label: string; desc: string }[];
}

const MONTH_NUMS: Record<string, string> = {
  january:'01', february:'02', march:'03', april:'04',
  may:'05', june:'06', july:'07', august:'08',
  september:'09', october:'10', november:'11', december:'12',
};
const MONTH_NAMES: Record<string, string> = {
  '01':'January','02':'February','03':'March','04':'April',
  '05':'May','06':'June','07':'July','08':'August',
  '09':'September','10':'October','11':'November','12':'December',
};

const changelogPath = path.join(process.cwd(), 'src/content/field-notes/building-this-garden.md');
const changelogRaw  = fs.readFileSync(changelogPath, 'utf-8');
const dayChunks     = changelogRaw.split(/(?=^### \d{1,2} [A-Za-z]+\s*$)/m);
const clEntries: ChangelogEntry[] = [];

for (const chunk of dayChunks) {
  const hm = chunk.match(/^### (\d{1,2}) ([A-Za-z]+)/m);
  if (!hm) continue;
  const day    = hm[1].padStart(2, '0');
  const mNum   = MONTH_NUMS[hm[2].toLowerCase()];
  if (!mNum) continue;
  const isoDate     = `2026-${mNum}-${day}`;
  const displayDate = `${parseInt(hm[1])} ${hm[2]}`;
  const monthKey    = `2026-${mNum}`;
  const monthLabel  = `${MONTH_NAMES[mNum]} 2026`;
  const body        = chunk.slice(chunk.indexOf('\n') + 1);
  const lines       = body.split('\n');
  const intro       = lines.find(l => l.trim() && !l.trim().startsWith('-'))?.trim() ?? '';
  const bullets     = lines
    .filter(l => l.trim().startsWith('- '))
    .map(l => {
      const content = l.trim().slice(2);
      const bm = content.match(/^\*\*([^*]+)\*\*[:\s]+(.*)/);
      return bm ? { label: bm[1], desc: bm[2] } : { label: '', desc: content };
    });
  clEntries.push({ isoDate, displayDate, monthKey, monthLabel, intro, bullets });
}

clEntries.sort((a, b) => b.isoDate.localeCompare(a.isoDate));

const byMonth: Record<string, ChangelogEntry[]> = {};
for (const e of clEntries) {
  if (!byMonth[e.monthKey]) byMonth[e.monthKey] = [];
  byMonth[e.monthKey].push(e);
}
const monthKeys = Object.keys(byMonth).sort((a, b) => b.localeCompare(a));

// ── Kanban column config ────────────────────────────────────────────────────

const columns = [
  {
    key: 'ready', label: 'Ready', emoji: '🟡',
    strip: '#EDE8D5', stripDark: '#282510',
    accent: '#9a7a00', accentDark: '#e0b830',
    items: backlog.ready,
  },
  {
    key: 'inProgress', label: 'In progress', emoji: '🔵',
    strip: '#D4DDE8', stripDark: '#10182A',
    accent: '#2a5fa0', accentDark: '#6aabff',
    items: backlog.inProgress,
  },
  {
    key: 'parked', label: 'Parked', emoji: '🟠',
    strip: '#EDE0D0', stripDark: '#281e10',
    accent: '#a05020', accentDark: '#e08050',
    items: backlog.parked,
  },
  {
    key: 'done', label: 'Done', emoji: '✅',
    strip: '#D5E8D8', stripDark: '#102015',
    accent: '#2a6a40', accentDark: '#5ecb8a',
    items: backlog.done,
  },
];
---

<BaseLayout title={`Garden ops — ${settings.siteTitle}`} description="Backlog, health metrics, and release notes for this garden.">
  <SketchyFilter />
  <Header />

  <div class="ts-page">
    <main class="ts-main">

      <div class="ts-heading">
        <h1>🔧 Garden ops</h1>
        <p class="ts-desc">Backlog, health, release notes. The work happens in <code>.claude/</code>: this is the window.</p>
      </div>

      <!-- ── Kanban ── -->
      <section class="ts-section">
        <h2 class="ts-section-title">Backlog</h2>
        <div class="ts-kanban">
          {columns.map(col => (
            <div
              class="ts-column"
              style={`--col-strip: ${col.strip}; --col-strip-dark: ${col.stripDark}; --col-accent: ${col.accent}; --col-accent-dark: ${col.accentDark};`}
            >
              <div class="ts-column-header">
                <span class="ts-column-emoji">{col.emoji}</span>
                <span class="ts-column-label">{col.label}</span>
                <span class="ts-column-count">{col.items.length}</span>
              </div>
              <div class="ts-cards">
                {col.items.length === 0 && (
                  <p class="ts-empty">Nothing here</p>
                )}
                {col.items.map((item) => (
                  <button
                    class="ts-card"
                    data-title={item.title}
                    data-meta={item.meta}
                    data-body={item.bodyFull}
                    aria-label={`Open: ${item.title}`}
                  >
                    <div class="ts-card-strip"></div>
                    <div class="ts-card-main">
                      <div class="ts-card-meta-bar">
                        <span class="ts-card-status">{col.label}</span>
                        {item.meta && <span class="ts-card-date">{item.meta.split('·')[0].trim().replace(/^\*+|\*+$/g, '')}</span>}
                      </div>
                      <div class="ts-card-body">
                        <span class="ts-card-title">{item.title}</span>
                        {item.body && (
                          <span class="ts-card-preview">{item.body}{item.bodyFull.length > 200 ? '…' : ''}</span>
                        )}
                      </div>
                    </div>
                  </button>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Lower two-column section ── -->
      <div class="ts-lower">

        <!-- Left: release notes -->
        <section class="ts-section ts-release-notes">
          <h2 class="ts-section-title">Release notes</h2>
          <p class="ts-release-link"><a href="/field-notes/building-this-garden/">Full changelog</a></p>
          {monthKeys.map((key, i) => (
            <details class="ts-month-group" open={i === 0}>
              <summary class="ts-month-toggle">
                <span>{byMonth[key][0].monthLabel}</span>
                <span class="ts-month-count">{byMonth[key].length}</span>
              </summary>
              <div class="ts-month-entries">
                {byMonth[key].map(entry => (
                  <details class="ts-entry">
                    <summary class="ts-entry-summary">
                      <time class="ts-entry-date">{entry.displayDate}</time>
                      <span class="ts-entry-intro">{entry.intro}</span>
                    </summary>
                    <ul class="ts-entry-bullets">
                      {entry.bullets.map(b => (
                        <li>
                          {b.label && <strong>{b.label}</strong>}
                          {b.label ? ': ' : ''}{b.desc}
                        </li>
                      ))}
                    </ul>
                  </details>
                ))}
              </div>
            </details>
          ))}
        </section>

        <!-- Right sidebar -->
        <aside class="ts-sidebar">

          <!-- Garden health -->
          <div class="ts-panel" data-label="Garden health">
            <ul class="ts-health-list">
              <li class:list={['ts-health-item', { 'ts-health-warn': brokenLinkCount > 0 }]}>
                <span class="ts-health-icon">{brokenLinkCount === 0 ? '✓' : '!'}</span>
                <span>{brokenLinkCount === 0 ? 'No broken wiki links' : `${brokenLinkCount} broken wiki link${brokenLinkCount !== 1 ? 's' : ''}`}</span>
              </li>
              <li class:list={['ts-health-item', { 'ts-health-warn': tagTableRows > 0 }]}>
                <span class="ts-health-icon">{tagTableRows === 0 ? '✓' : '!'}</span>
                <span>{tagTableRows === 0 ? 'No tag near-duplicates' : `${tagTableRows} tag near-duplicate${tagTableRows !== 1 ? 's' : ''} flagged`}</span>
              </li>
              <li class:list={['ts-health-item', { 'ts-health-warn': missingDescCount > 0 }]}>
                <span class="ts-health-icon">{missingDescCount === 0 ? '✓' : '!'}</span>
                <span>{missingDescCount === 0 ? 'All descriptions present' : `${missingDescCount} library descriptions missing`}</span>
              </li>
            </ul>
            <p class="ts-health-date">Last scan: {healthDate}</p>
          </div>

          <!-- Toolshed sections -->
          <div class="ts-panel" data-label="Toolshed">
            <nav class="ts-nav-list">
              <a href="/toolshed/design" class="ts-nav-item">
                <span class="ts-nav-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M3 12h3m12 0h3M12 3v3m0 12v3"/></svg>
                </span>
                <span>Visual design</span>
              </a>
              <a href="/toolshed/technical" class="ts-nav-item">
                <span class="ts-nav-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                </span>
                <span>Tech specs</span>
              </a>
            </nav>
          </div>

        </aside>
      </div>

    </main>
  </div>

  <Footer />
</BaseLayout>

<!-- Modal overlay -->
<div class="ts-modal" id="ts-modal" aria-hidden="true" role="dialog" aria-labelledby="ts-modal-title" aria-modal="true">
  <div class="ts-modal-backdrop" id="ts-modal-backdrop"></div>
  <div class="ts-modal-panel">
    <button class="ts-modal-close" id="ts-modal-close" aria-label="Close">×</button>
    <p class="ts-modal-meta" id="ts-modal-meta"></p>
    <h2 class="ts-modal-title" id="ts-modal-title"></h2>
    <div class="ts-modal-body" id="ts-modal-body"></div>
  </div>
</div>

<script>
  function initToolshed() {
    const modal    = document.getElementById('ts-modal') as HTMLElement;
    const backdrop = document.getElementById('ts-modal-backdrop') as HTMLElement;
    const closeBtn = document.getElementById('ts-modal-close') as HTMLButtonElement;
    const modalTitle = document.getElementById('ts-modal-title') as HTMLElement;
    const modalMeta  = document.getElementById('ts-modal-meta') as HTMLElement;
    const modalBody  = document.getElementById('ts-modal-body') as HTMLElement;

    function openModal(card: HTMLElement) {
      const title    = card.dataset.title ?? '';
      const meta     = card.dataset.meta  ?? '';
      const bodyText = card.dataset.body  ?? '';

      modalTitle.textContent = title;
      modalMeta.textContent  = meta;

      const html = bodyText
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/`([^`]+)`/g, '<code>$1</code>')
        .replace(/\n/g, '<br>');
      modalBody.innerHTML = html;

      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }

    function closeModal() {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLElement>('.ts-card').forEach(card => {
      card.addEventListener('click', () => openModal(card));
    });

    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
    });
  }

  initToolshed();
  document.addEventListener('astro:after-swap', initToolshed);

</script>

<style>
  /* ── Page background ── */
  .ts-page {
    background: #F2F3F5;
    min-height: calc(100vh - 200px);
  }
  :root[data-theme="dark"] .ts-page { background: #141618; }

  .ts-main {
    max-width: 78rem;
    margin: 0 auto;
    padding: var(--space-2xl) var(--space-lg) var(--space-3xl);
  }

  .ts-heading {
    margin-bottom: var(--space-2xl);
  }
  .ts-heading h1 {
    font-size: 2rem;
    margin-bottom: var(--space-xs);
  }
  .ts-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
  .ts-desc code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: rgba(0,0,0,0.07);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  :root[data-theme="dark"] .ts-desc code { background: rgba(255,255,255,0.08); }

  /* ── Section title ── */
  .ts-section-title {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  /* ── Kanban ── */
  .ts-kanban {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  /* ── Column ── */
  .ts-column {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ts-column-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem var(--space-sm) 0.4rem var(--space-sm);
    background: var(--col-strip);
    border-radius: 0.5rem 0.5rem 0 0;
    border-bottom: 2px solid rgba(0,0,0,0.08);
  }
  :root[data-theme="dark"] .ts-column-header { background: var(--col-strip-dark); border-bottom-color: rgba(255,255,255,0.06); }

  .ts-column-emoji { font-size: 0.8rem; line-height: 1; }

  .ts-column-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--col-accent);
    flex: 1;
  }
  :root[data-theme="dark"] .ts-column-label { color: var(--col-accent-dark); }

  .ts-column-count {
    font-size: 0.62rem;
    font-weight: 600;
    background: rgba(0,0,0,0.1);
    border-radius: 1rem;
    padding: 0.1em 0.45em;
    color: var(--col-accent);
    line-height: 1.6;
  }
  :root[data-theme="dark"] .ts-column-count { background: rgba(255,255,255,0.1); color: var(--col-accent-dark); }

  .ts-cards {
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: rgba(0,0,0,0.04);
    border-radius: 0 0 0.5rem 0.5rem;
    padding: 2px;
    min-height: 80px;
  }
  :root[data-theme="dark"] .ts-cards { background: rgba(255,255,255,0.03); }

  .ts-empty {
    padding: var(--space-sm);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-style: italic;
    text-align: center;
    margin: auto;
  }

  /* ── Kanban card (mosaic-style) ── */
  .ts-card {
    display: flex;
    flex-direction: row;
    text-align: left;
    background: #FFFFFF;
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    overflow: hidden;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
    width: 100%;
    padding: 0;
  }
  :root[data-theme="dark"] .ts-card { background: var(--color-bg-card); }
  .ts-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    border-color: transparent;
  }

  /* Strip — left color bar */
  .ts-card-strip {
    width: 10px;
    flex-shrink: 0;
    background: var(--col-strip);
  }
  :root[data-theme="dark"] .ts-card-strip { background: var(--col-strip-dark); }

  /* Main content */
  .ts-card-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    border-inline-start: 2px double rgba(140, 100, 80, 0.25);
    min-width: 0;
  }

  /* Meta bar */
  .ts-card-meta-bar {
    display: flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.3rem 0.6rem;
    border-block-end: 3px double rgba(180, 60, 60, 0.25);
  }
  .ts-card-status {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--col-accent);
  }
  :root[data-theme="dark"] .ts-card-status { color: var(--col-accent-dark); }
  .ts-card-date {
    font-size: 0.58rem;
    color: var(--color-text-muted);
    margin-inline-start: auto;
  }

  /* Body */
  .ts-card-body {
    padding: 0.4rem 0.6rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .ts-card-title {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.3;
  }
  .ts-card-preview {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Lower section ── */
  .ts-lower {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* ── Release notes ── */
  .ts-release-link {
    font-size: 0.78rem;
    margin: calc(-1 * var(--space-xs)) 0 var(--space-md);
  }
  .ts-release-link a { color: var(--color-accent); text-decoration: none; }
  .ts-release-link a:hover { text-decoration: underline; }

  .ts-month-group { margin-bottom: var(--space-md); }
  .ts-month-toggle {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    cursor: pointer;
    list-style: none;
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    user-select: none;
  }
  .ts-month-toggle::-webkit-details-marker { display: none; }
  .ts-month-toggle::before {
    content: '▸';
    font-size: 0.58rem;
    transition: transform 0.15s;
  }
  details[open] > .ts-month-toggle::before { transform: rotate(90deg); }
  .ts-month-count { margin-left: auto; font-weight: 400; opacity: 0.6; }

  .ts-month-entries { display: flex; flex-direction: column; gap: 0; }

  .ts-entry { border-bottom: 1px solid var(--color-border); }
  .ts-entry-summary {
    display: flex;
    gap: var(--space-sm);
    align-items: baseline;
    padding: 0.35rem 0;
    cursor: pointer;
    list-style: none;
    font-size: 0.82rem;
  }
  .ts-entry-summary::-webkit-details-marker { display: none; }
  .ts-entry-summary::before {
    content: '▸';
    font-size: 0.55rem;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform 0.15s;
    align-self: center;
  }
  .ts-entry[open] > .ts-entry-summary::before { transform: rotate(90deg); }

  .ts-entry-date {
    flex-shrink: 0;
    font-size: 0.66rem;
