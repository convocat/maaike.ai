---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('toolshed');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const backHref = entry.data.category === 'design' ? '/toolshed/design'
  : entry.data.category === 'content' ? '/toolshed/content-design'
  : entry.data.category === 'technical' ? '/toolshed/technical'
  : '/toolshed';
const backLabel = entry.data.category === 'design' ? 'Visual design'
  : entry.data.category === 'content' ? 'Content design'
  : entry.data.category === 'technical' ? 'Tech specs'
  : 'Toolshed';
---

<PostLayout
  title={entry.data.title}
  date={entry.data.date}
  updated={entry.data.updated}
  maturity={entry.data.maturity}
  tags={entry.data.tags}
  description={entry.data.description}
  collection="toolshed"
  slug={entry.id}
  ai={entry.data.ai}
  hub={entry.data.hub}
  develops={entry.data.develops}
  triples={entry.data.triples}
  themes={entry.data.themes}
  backHref={backHref}
  backLabel={backLabel}
>
  <Content />
</PostLayout>
