---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const jottings = await getCollection('jottings');
  return jottings.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const url = entry.data.url ?? '';
function getYouTubeId(u: string) {
  const m = u.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([^?&]+)/);
  return m ? m[1] : null;
}
const youtubeId = getYouTubeId(url);
---

<PostLayout
  title={entry.data.title}
  date={entry.data.date}
  updated={entry.data.updated}
  maturity={entry.data.maturity}
  tags={entry.data.tags}
  description={entry.data.description}
  collection="jottings"
  slug={entry.id}
  ai={entry.data.ai}
  hub={entry.data.hub}
  develops={entry.data.develops}
  triples={entry.data.triples}
  themes={entry.data.themes}
>
  {youtubeId && (
    <div class="video-embed" style="margin-bottom: var(--space-xl)">
      <div class="video-wrapper" style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:8px">
        <iframe
          src={`https://www.youtube.com/embed/${youtubeId}`}
          style="position:absolute;top:0;left:0;width:100%;height:100%;border:0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        />
      </div>
    </div>
  )}
  <Content />
</PostLayout>
