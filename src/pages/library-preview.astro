---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SketchyFilter from '../components/SketchyFilter.astro';
import { sortByDate } from '../utils/collections';

const books = sortByDate(
  (await getCollection('library')).filter(e => !e.data.draft)
);

function fmtDate(d?: Date): string {
  if (!d) return '';
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }).toUpperCase();
}

const statusMeta: Record<string, { label: string; bg: string; color: string; dot: string }> = {
  'reading': { label: 'Reading', bg: '#dbeafe', color: '#1e40af', dot: '#2563eb' },
  'read':    { label: 'Read',    bg: '#dcfce7', color: '#166534', dot: '#16a34a' },
  'to-read': { label: 'To read', bg: '#f3f4f6', color: '#6b7280', dot: '#9ca3af' },
};

// Palette of warm colors for cover placeholders
const placeholderColors = [
  '#C9B8AE', '#B8C4BE', '#C4B8C9', '#BCBEAD', '#C9BEB8',
  '#AEC4BC', '#C4AEAE', '#B8C4C4', '#C4C4AE', '#AEB8C4',
];
function placeholderColor(title: string): string {
  let h = 0;
  for (let i = 0; i < title.length; i++) h = (h * 31 + title.charCodeAt(i)) & 0xffffff;
  return placeholderColors[Math.abs(h) % placeholderColors.length];
}

// Category definitions — tag-based matching (same as original FilterBar)
const categoryDefs = [
  { key: 'conversation-design', emoji: '🤖', label: 'Conversation design',
    tags: ['chatbots','conversational-ai','conversation-design','human-computer-interaction','interaction-design','user-interfaces','voice-design','voice-user-interface-design','voice-user-interfaces','voice-ux','human-machine-interface-design','robots'] },
  { key: 'conversational-analysis', emoji: '🕵️', label: 'Conversational analysis',
    tags: ['conversation-analysis','conversational-patterns','pragmatics','discourse','sociolinguistics','expandable-sequences','turn-construction-units','linguistics','phonetics','speech-processing','acoustics','conversational-grounding'] },
  { key: 'content-architecture', emoji: '⛏️', label: 'Content architecture',
    tags: ['content-architecture','content-strategy','knowledge-management','taxonomy','ontology','personal-knowledge-systems','methodology','semiotics'] },
  { key: 'nlp-speech', emoji: '🔊', label: 'NLP/NLU & speech',
    tags: ['natural-language-processing','computational-linguistics','speech-processing','python','phonetics','acoustics','llm','generative-ai'] },
  { key: 'feminism-ethics', emoji: '🥇', label: 'Feminism, bias, ethics',
    tags: ['feminism','feminist-literature','ethics','misogyny','social-psychology','sociology','cultural-theory','posthumanism'] },
  { key: 'accessibility', emoji: '♿', label: 'Accessibility',
    tags: ['accessibility','human-factors','inclusive-design','design'] },
  { key: 'writing', emoji: '📝', label: 'Writing',
    tags: ['writing','typography','rhetoric','internet-language','poetry','media-studies'] },
  { key: 'general', emoji: '🌐', label: 'General interest',
    tags: ['fiction','literary-fiction','science-fiction','fantasy','biography','history','ecology','philosophy','memoir','mental-health','self-development','science','economics','leadership','business','cognitive-science','psychology','psychologie','non-fictie','essay','classic','short-stories','future','kinderboek','reizen'] },
];

// Compute category keys for each book from its tags
function bookCategories(tags: string[] = []): string {
  return categoryDefs
    .filter(cat => tags.some(t => cat.tags.includes(t)))
    .map(c => c.key)
    .join(',');
}

const statuses = [
  { value: 'reading', label: '📖 Reading' },
  { value: 'read', label: '✓ Read' },
  { value: 'to-read', label: '◦ To read' },
];

const bookTypes = [
  { value: 'fiction', label: 'Fiction' },
  { value: 'non-fiction', label: 'Non-fiction' },
];

const sortOptions = [
  { value: 'date', label: 'Date added' },
  { value: 'title', label: 'Title A–Z' },
  { value: 'author', label: 'Author A–Z' },
  { value: 'tended', label: 'Last tended' },
];
---

<BaseLayout title="Library preview — Maai & AI">
  <SketchyFilter />
  <Header />

  <div class="preview-banner">
    <span class="preview-badge">PREVIEW</span>
    <span>Design review only. <a href="/library">Go to the real library →</a></span>
  </div>

  <main class="preview-main">

    <!-- Two-column layout: sidebar + main -->
    <div class="lib-layout">

      <!-- Sidebar -->
      <aside class="lib-sidebar">

        <div class="filter-panel" data-label="Status">
          <div class="filter-items">
            {statuses.map(s => (
              <label class="filter-item">
                <span class="filter-checkbox" aria-hidden="true">
                  <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.5" width="10" height="10"><polyline points="2 6 5 9 10 3"/></svg>
                </span>
                <input type="checkbox" class="filter-cb-input sr-only status-cb" value={s.value} />
                <span class="filter-content"><span>{s.label}</span></span>
              </label>
            ))}
          </div>
        </div>

        <div class="filter-panel" data-label="Topic">
          <div class="filter-items">
            {categoryDefs.map(cat => (
              <label class="filter-item">
                <span class="filter-checkbox" aria-hidden="true">
                  <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.5" width="10" height="10"><polyline points="2 6 5 9 10 3"/></svg>
                </span>
                <input type="checkbox" class="filter-cb-input sr-only cat-cb" value={cat.key} />
                <span class="filter-content"><span>{cat.emoji} {cat.label}</span></span>
              </label>
            ))}
          </div>
        </div>

        <div class="filter-panel" data-label="Book type">
          <div class="filter-items">
            {bookTypes.map(t => (
              <label class="filter-item">
                <span class="filter-checkbox" aria-hidden="true">
                  <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2.5" width="10" height="10"><polyline points="2 6 5 9 10 3"/></svg>
                </span>
                <input type="checkbox" class="filter-cb-input sr-only type-cb" value={t.value} />
                <span class="filter-content"><span>{t.label}</span></span>
              </label>
            ))}
          </div>
        </div>

        <div class="filter-panel" data-label="Sort by">
          <div class="filter-items filter-items--radio">
            {sortOptions.map((s, i) => (
              <label class="filter-item">
                <span class="filter-radio-dot" aria-hidden="true"></span>
                <input type="radio" class="filter-cb-input sr-only sort-rb" name="sort" value={s.value} checked={i === 0} />
                <span class="filter-content"><span>{s.label}</span></span>
              </label>
            ))}
          </div>
        </div>

        <div class="lib-recommender-card">
          <div class="recommender-strip"></div>
          <div class="recommender-body">
            <p class="recommender-heading">Not sure what to read?</p>
            <button class="recommender-cta">Pick for me →</button>
          </div>
        </div>

      </aside>

      <!-- Main content -->
      <div class="lib-main">

        <!-- Toolbar: count + view toggle -->
        <div class="lib-toolbar">
          <span class="lib-count" id="lib-count">{books.length} books</span>
          <div class="view-toggle" role="group" aria-label="Display mode">
            <button class="view-btn active" data-view="cards" aria-pressed="true">
              <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><rect x="1" y="1" width="6" height="9" rx="1"/><rect x="9" y="1" width="6" height="9" rx="1"/></svg>
              Cards
            </button>
            <button class="view-btn" data-view="list" aria-pressed="false">
              <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor" aria-hidden="true"><rect x="1" y="2" width="14" height="2" rx="1"/><rect x="1" y="7" width="14" height="2" rx="1"/><rect x="1" y="12" width="14" height="2" rx="1"/></svg>
              List
            </button>
            <button class="view-btn" data-view="covers" aria-pressed="false">
              <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor" aria-hidden="true"><rect x="1" y="1" width="4" height="6" rx="1"/><rect x="6" y="1" width="4" height="6" rx="1"/><rect x="11" y="1" width="4" height="6" rx="1"/><rect x="1" y="9" width="4" height="6" rx="1"/><rect x="6" y="9" width="4" height="6" rx="1"/><rect x="11" y="9" width="4" height="6" rx="1"/></svg>
              Covers
            </button>
          </div>
        </div>

        <div class="lib-grid" id="lib-grid" data-view="cards">

          {books.map((book) => {
            const d = book.data;
            const sm = statusMeta[d.status as string] ?? statusMeta['to-read'];
            const bgColor = placeholderColor(d.title);
            const cats = bookCategories(d.tags ?? []);
            return (
              <a
                href={`/library/${book.id}`}
                class="book-card"
                data-status={d.status}
                data-booktype={d.book_type ?? 'non-fiction'}
                data-tags={(d.tags ?? []).join(',')}
                data-categories={cats}
                data-date={d.date?.toISOString() ?? ''}
                data-updated={d.updated?.toISOString() ?? ''}
                data-title={d.title}
                data-author={d.author ?? ''}
              >
                {/* Cards view: stream aesthetic */}
                <div class="bc-card-inner">
                  <div class="bc-strip">
                    <img src="/images/icons/bookmark.svg" alt="" class="bc-strip-icon" width="24" height="24" />
                  </div>
                  <div class="bc-main">
                    <div class="bc-meta-bar">
                      <span class="bc-status-dot" style={`background:${sm.dot}`}></span>
                      <span class="bc-meta-status">{sm.label}</span>
                      <span class="bc-meta-dot">·</span>
                      <time class="bc-meta-date">{fmtDate(d.date)}</time>
                      {d.updated && (
                        <Fragment>
                          <span class="bc-meta-dot">·</span>
                          <span class="bc-meta-tended">TENDED {fmtDate(d.updated)}</span>
                        </Fragment>
                      )}
                    </div>
                    <div class="bc-body">
                      {d.cover ? (
                        <img src={d.cover} alt={`Cover of ${d.title}`} class="bc-cover" loading="lazy" />
                      ) : (
                        <div class="bc-cover-placeholder" style={`background:${bgColor}`}>
                          <span>{d.title.charAt(0).toUpperCase()}</span>
                        </div>
                      )}
                      <div class="bc-text">
                        <h3 class="bc-title">{d.title}</h3>
                        <span class="bc-author">{d.author}</span>
                        {d.description && <p class="bc-desc">{d.description}</p>}
                      </div>
                    </div>
                  </div>
                </div>

                {/* List view: compact row */}
                <div class="bc-list-row">
                  {d.cover ? (
                    <img src={d.cover} alt="" class="bc-list-cover" loading="lazy" />
                  ) : (
                    <div class="bc-list-placeholder" style={`background:${bgColor}`}>{d.title.charAt(0).toUpperCase()}</div>
                  )}
                  <span class="bc-list-title">{d.title}</span>
                  <span class="bc-list-author">{d.author}</span>
                  <span class="bc-list-status" style={`background:${sm.bg};color:${sm.color}`}>{sm.label}</span>
                  {d.description && <span class="bc-list-desc">{d.description}</span>}
                </div>

                {/* Covers view: shelf */}
                <div class="bc-shelf">
                  {d.cover ? (
                    <img src={d.cover} alt={`Cover of ${d.title}`} class="bc-shelf-img" loading="lazy" />
                  ) : (
                    <div class="bc-shelf-placeholder" style={`background:${bgColor}`}>
                      <span>{d.title.charAt(0).toUpperCase()}</span>
                    </div>
                  )}
                  <div class="bc-shelf-overlay">
                    <span class="bc-shelf-title">{d.title}</span>
                    <span class="bc-shelf-author">{d.author}</span>
                  </div>
                </div>
              </a>
            );
          })}

        </div>

        <p class="lib-empty" id="lib-empty" hidden>No books match the current filters.</p>
        <nav class="lib-pagination" id="lib-pagination" aria-label="Library pages" hidden>
          <button class="page-btn" id="page-prev" aria-label="Previous page">&larr; Previous</button>
          <span class="page-indicator" id="page-indicator"></span>
          <button class="page-btn" id="page-next" aria-label="Next page">Next &rarr;</button>
        </nav>

      </div>
    </div>
  </main>

  <!-- Recommender drawer (same as real library page) -->
  <div id="recommenderDrawer" class="drawer" aria-hidden="true">
    <div class="drawer-backdrop" id="drawerBackdrop"></div>
    <div class="drawer-panel" role="dialog" aria-label="What to read next?">
      <div class="drawer-header">
        <span class="drawer-title">📚 What to read next?</span>
        <button class="drawer-close" id="drawerClose" aria-label="Close">✕</button>
      </div>
      <iframe src="/dashboard.html?embed=1" class="drawer-iframe" title="Book recommender"></iframe>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script>
  const PAGE_SIZE = window.innerWidth <= 800 ? 6 : 12;

  function initLibrary() {
    const grid       = document.getElementById('lib-grid') as HTMLElement | null;
    const emptyEl    = document.getElementById('lib-empty') as HTMLElement | null;
    const pagination = document.getElementById('lib-pagination') as HTMLElement | null;
    const prevBtn    = document.getElementById('page-prev') as HTMLButtonElement | null;
    const nextBtn    = document.getElementById('page-next') as HTMLButtonElement | null;
    const indicator  = document.getElementById('page-indicator') as HTMLElement | null;
    const countEl    = document.getElementById('lib-count') as HTMLElement | null;
    if (!grid) return;

    const allCards = Array.from(grid.querySelectorAll<HTMLElement>('.book-card'));
    let currentPage = 1;

    // ── Matching ──
    function matchesFilters(card: HTMLElement): boolean {
      const activeStatuses = [...document.querySelectorAll<HTMLInputElement>('.status-cb:checked')].map(i => i.value);
      const activeCats     = [...document.querySelectorAll<HTMLInputElement>('.cat-cb:checked')].map(i => i.value);
      const activeTypes    = [...document.querySelectorAll<HTMLInputElement>('.type-cb:checked')].map(i => i.value);

      const statusOk = activeStatuses.length === 0 || activeStatuses.includes(card.dataset.status ?? '');
      const typeOk   = activeTypes.length === 0   || activeTypes.includes(card.dataset.booktype ?? '');
      const cardCats = (card.dataset.categories ?? '').split(',').filter(Boolean);
      const catOk    = activeCats.length === 0    || activeCats.some(c => cardCats.includes(c));

      return statusOk && typeOk && catOk;
    }

    // ── Render page ──
    function render() {
      const matching    = allCards.filter(matchesFilters);
      const totalPages  = Math.max(1, Math.ceil(matching.length / PAGE_SIZE));
      if (currentPage > totalPages) currentPage = totalPages;

      const start = (currentPage - 1) * PAGE_SIZE;
      const end   = start + PAGE_SIZE;

      allCards.forEach(c => { c.style.display = 'none'; });
      matching.slice(start, end).forEach(c => { c.style.display = ''; });

      if (countEl)   countEl.textContent = `${matching.length} book${matching.length !== 1 ? 's' : ''}`;
      if (emptyEl)   emptyEl.hidden = matching.length > 0;
      if (pagination) pagination.hidden = totalPages <= 1;
      if (indicator) indicator.textContent = `Page ${currentPage} of ${totalPages}`;
      if (prevBtn)   prevBtn.disabled = currentPage === 1;
      if (nextBtn)   nextBtn.disabled = currentPage === totalPages;
    }

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
    });
    nextBtn?.addEventListener('click', () => {
      currentPage++; render(); window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // ── Filters reset page ──
    document.querySelectorAll('.status-cb, .cat-cb, .type-cb').forEach(cb => {
      cb.addEventListener('change', () => { currentPage = 1; render(); });
    });

    // ── Sort re-orders DOM then re-renders ──
    document.querySelectorAll('.sort-rb').forEach(rb => {
      rb.addEventListener('change', () => {
        const sortVal = (document.querySelector<HTMLInputElement>('.sort-rb:checked')?.value) ?? 'date';
        allCards.sort((a, b) => {
          if (sortVal === 'title')  return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '');
          if (sortVal === 'author') return (a.dataset.author ?? '').localeCompare(b.dataset.author ?? '');
          if (sortVal === 'tended') return (b.dataset.updated ?? b.dataset.date ?? '').localeCompare(a.dataset.updated ?? a.dataset.date ?? '');
          return (b.dataset.date ?? '').localeCompare(a.dataset.date ?? '');
        });
        allCards.forEach(c => grid.appendChild(c));
        currentPage = 1;
        render();
      });
    });

    // ── View switching ──
    document.querySelectorAll<HTMLButtonElement>('.view-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.view-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        grid.dataset.view = btn.dataset.view!;
      });
    });

    // ── Recommender drawer ──
    const drawer     = document.getElementById('recommenderDrawer');
    const backdrop   = document.getElementById('drawerBackdrop');
    const drawerClose = document.getElementById('drawerClose');

    function openDrawer() {
      drawer?.classList.add('open');
      drawer?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer?.classList.remove('open');
      drawer?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    document.querySelector('.recommender-cta')?.addEventListener('click', openDrawer);
    backdrop?.addEventListener('click', closeDrawer);
    drawerClose?.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });

    render();
  }

  initLibrary();
  document.addEventListener('astro:after-swap', initLibrary);
</script>

<style>
  .preview-banner {
    background: #FEF3C7;
    border-bottom: 1px solid #F59E0B;
    padding: 0.4rem 2rem;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #92400E;
  }
  :root[data-theme="dark"] .preview-banner { background: #2a2000; border-color: #92400E; color: #FCD34D; }
  .preview-banner a { color: inherit; font-weight: 600; }
  .preview-badge {
    font-size: 0.58rem; font-weight: 800; letter-spacing: 0.1em;
    background: #F59E0B; color: #fff; padding: 0.15em 0.5em; border-radius: 3px;
  }

  .preview-main {
    max-width: var(--max-width, 75rem);
    margin: 0 auto;
    padding: var(--space-xl) var(--space-md) var(--space-3xl);
  }

  /* ── Layout ── */
  .lib-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* ── Sidebar ── */
  .lib-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* Folder-tab filter panels — library sand */
  .filter-panel {
    position: relative;
    background: #F0EAE4;
    border-radius: 0 0.75rem 0.75rem 0.75rem;
    padding: var(--space-sm) var(--space-md) var(--space-md);
    margin-top: 1.5rem;
  }
  :root[data-theme="dark"] .filter-panel { background: #231e1b; }

  .filter-panel::before {
    content: attr(data-label);
    position: absolute;
    top: -1.35rem;
    left: 0;
    padding: 0.22rem 0.75rem;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--color-text-muted);
    background: #F0EAE4;
    border-radius: 5px 5px 0 0;
    white-space: nowrap;
  }
  :root[data-theme="dark"] .filter-panel::before { background: #231e1b; }

  .filter-items { display: flex; flex-direction: column; gap: 0; }

  .filter-item {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.18rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .filter-item:hover { background: rgba(255,255,255,0.6); }
  :root[data-theme="dark"] .filter-item:hover { background: rgba(255,255,255,0.06); }

  .filter-checkbox {
    opacity: 0;
    position: absolute;
    left: 12px;
    width: 16px; height: 16px;
    border-radius: 3px;
    border: 1.5px solid #C4B8B0;
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .filter-item:hover .filter-checkbox { opacity: 1; }
  .filter-item:has(input:checked) .filter-checkbox {
    opacity: 1; background: var(--color-accent); border-color: var(--color-accent);
  }

  .filter-radio-dot {
    opacity: 0;
    position: absolute;
    left: 12px;
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 1.5px solid #C4B8B0;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .filter-item:hover .filter-radio-dot { opacity: 1; }
  .filter-item:has(input:checked) .filter-radio-dot {
    opacity: 1;
    border-color: var(--color-accent);
    background: radial-gradient(circle at center, var(--color-accent) 40%, transparent 40%);
  }

  .filter-content {
    display: flex; align-items: center; gap: 6px;
    transition: transform 0.15s ease;
  }
  .filter-item:hover .filter-content,
  .filter-item:has(input:checked) .filter-content { transform: translateX(28px); }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  /* Recommender CTA */
  .lib-recommender-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    margin-top: var(--space-sm);
  }
  .recommender-strip { height: 6px; background: var(--color-accent); }
  .recommender-body { padding: var(--space-sm) var(--space-md) var(--space-md); }
  .recommender-heading { font-size: 0.78rem; color: var(--color-text-muted); margin: 0 0 var(--space-sm) 0; }
  .recommender-cta {
    background: var(--color-accent); color: #fff; border: none;
    border-radius: 1rem; padding: 0.3em 0.9em;
    font-size: 0.78rem; font-weight: 600; font-family: inherit;
    cursor: pointer; transition: opacity 0.15s;
  }
  .recommender-cta:hover { opacity: 0.85; }

  /* ── Toolbar ── */
  .lib-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: var(--space-md);
  }
  .lib-count { font-size: 0.78rem; color: var(--color-text-muted); }

  .view-toggle {
    display: flex; gap: 2px;
    background: var(--color-border);
    border-radius: 0.5rem;
    padding: 2px;
  }
  .view-btn {
