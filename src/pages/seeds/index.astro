---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ContentGrid from '../../components/ContentGrid.astro';
import ContentCard from '../../components/ContentCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { sortByDate, getUniqueTags } from '../../utils/collections';
import settings from '../../data/settings.json';
import CollectionIcon from '../../components/CollectionIcon.astro';

const seeds = sortByDate(
  (await getCollection('seeds')).filter((e) => !e.data.draft && e.data.maturity !== 'compost')
);
const tags = getUniqueTags(seeds);
---

<PageLayout title={`${settings.seedsTitle} — ${settings.siteTitle}`}>
  <h1><CollectionIcon collection="seeds" size={28} /> {settings.seedsTitle}</h1>
  <p class="section-description">{settings.seedsDescription}</p>

  <FilterBar tags={tags} />

  <ContentGrid>
    {seeds.length > 0 ? (
      seeds.map((seed) => (
        <ContentCard
          title={seed.data.title}
          href={`/seeds/${seed.id}`}
          date={seed.data.date}
          updated={seed.data.updated}
          maturity={seed.data.maturity}
          tags={seed.data.tags}
          description={seed.data.description}
          collection="seeds"
        />
      ))
    ) : (
      <p class="empty-state">No seeds yet — ideas waiting to germinate will appear here.</p>
    )}
  </ContentGrid>
</PageLayout>

<style>
  h1 { display: flex; align-items: center; gap: var(--space-sm); margin-block-end: var(--space-xs); }
  .section-description {
    color: var(--color-text-muted);
    margin-block-end: var(--space-xl);
  }
  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
