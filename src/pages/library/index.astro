---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ContentGrid from '../../components/ContentGrid.astro';
import BookCard from '../../components/BookCard.astro';
import FilterBar from '../../components/FilterBar.astro';
import { sortByDate, getUniqueTags } from '../../utils/collections';
import settings from '../../data/settings.json';
import CollectionIcon from '../../components/CollectionIcon.astro';

const books = sortByDate(
  (await getCollection('library')).filter((e) => !e.data.draft)
);
const weblinks = sortByDate(
  (await getCollection('weblinks')).filter((e) => !e.data.draft)
);
const tags = getUniqueTags([...books, ...weblinks]);

const reading = books.filter((b) => b.data.status === 'reading');
const read = books.filter((b) => b.data.status === 'read');
const toRead = books.filter((b) => b.data.status === 'to-read');
---

<PageLayout title={`${settings.libraryTitle} — ${settings.siteTitle}`}>
  <h1><CollectionIcon collection="library" size={28} /> {settings.libraryTitle}</h1>
  <p class="section-description">{settings.libraryDescription}</p>

  <button id="recommenderBtn" class="recommender-btn">
    📚 What to read next?
  </button>

  {tags.length > 0 && <FilterBar tags={tags} />}

  {reading.length > 0 && (
    <section class="book-section">
      <h2>Currently reading</h2>
      <ContentGrid>
        {reading.map((book) => (
          <BookCard
            title={book.data.title}
            href={`/library/${book.id}`}
            author={book.data.author}
            cover={book.data.cover}
            status={book.data.status}
            maturity={book.data.maturity}
            tags={book.data.tags}
            description={book.data.description}
            date={book.data.date?.toISOString()}
            updated={book.data.updated?.toISOString()}
          />
        ))}
      </ContentGrid>
    </section>
  )}

  {read.length > 0 && (
    <section class="book-section">
      <h2>Read</h2>
      <ContentGrid>
        {read.map((book) => (
          <BookCard
            title={book.data.title}
            href={`/library/${book.id}`}
            author={book.data.author}
            cover={book.data.cover}
            status={book.data.status}
            maturity={book.data.maturity}
            tags={book.data.tags}
            description={book.data.description}
            date={book.data.date?.toISOString()}
            updated={book.data.updated?.toISOString()}
          />
        ))}
      </ContentGrid>
    </section>
  )}

  {toRead.length > 0 && (
    <section class="book-section">
      <h2>To read</h2>
      <ContentGrid>
        {toRead.map((book) => (
          <BookCard
            title={book.data.title}
            href={`/library/${book.id}`}
            author={book.data.author}
            cover={book.data.cover}
            status={book.data.status}
            maturity={book.data.maturity}
            tags={book.data.tags}
            description={book.data.description}
            date={book.data.date?.toISOString()}
            updated={book.data.updated?.toISOString()}
          />
        ))}
      </ContentGrid>
    </section>
  )}

  {weblinks.length > 0 && (
    <section class="book-section">
      <h2>Articles</h2>
      <ContentGrid>
        {weblinks.map((link) => (
          <a href={`/weblinks/${link.id}`} class="card article-card" data-tags={link.data.tags?.join(',')} data-maturity={link.data.maturity} data-date={link.data.date?.toISOString()}>
            <div class="article-info">
              <h3 class="article-title">{link.data.title}</h3>
              {link.data.description && <p class="article-desc">{link.data.description}</p>}
              <span class="article-source">{new URL(link.data.url).hostname}</span>
            </div>
          </a>
        ))}
      </ContentGrid>
    </section>
  )}

  {books.length === 0 && weblinks.length === 0 && (
    <p class="empty-state">No books or articles yet. Add one via the CMS.</p>
  )}

  <!-- Recommender drawer -->
  <div id="recommenderDrawer" class="drawer" aria-hidden="true">
    <div class="drawer-backdrop" id="drawerBackdrop"></div>
    <div class="drawer-panel" role="dialog" aria-label="What to read next?">
      <div class="drawer-header">
        <span class="drawer-title">📚 What to read next?</span>
        <button class="drawer-close" id="drawerClose" aria-label="Close">✕</button>
      </div>
      <iframe src="/dashboard.html?embed=1" class="drawer-iframe" title="Book recommender"></iframe>
    </div>
  </div>
</PageLayout>

<script>
  const btn = document.getElementById('recommenderBtn');
  const drawer = document.getElementById('recommenderDrawer');
  const backdrop = document.getElementById('drawerBackdrop');
  const closeBtn = document.getElementById('drawerClose');

  function openDrawer() {
    drawer?.classList.add('open');
    drawer?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer?.classList.remove('open');
    drawer?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openDrawer);
  backdrop?.addEventListener('click', closeDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });
</script>

<style>
  h1 { display: flex; align-items: center; gap: var(--space-sm); margin-block-end: var(--space-xs); }

  .recommender-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font: inherit;
    font-size: 0.82rem;
    font-weight: 500;
    color: #fff;
    background: var(--color-accent);
    border: none;
    border-radius: 1.5em;
    padding: 0.35em 0.9em;
    cursor: pointer;
    margin-block-end: var(--space-lg);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }
  .recommender-btn:hover { opacity: 0.88; transform: translateY(-1px); }

  .section-description {
    color: var(--color-text-muted);
    margin-block-end: var(--space-xl);
  }
  .book-section { margin-block-end: var(--space-2xl); }
  .book-section h2 { font-size: 1.2rem; margin-block-end: var(--space-md); }

  .article-card {
    display: block;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--color-shadow);
    border-color: transparent;
  }
  .article-title { font-size: 0.95rem; font-weight: 600; color: var(--color-heading); line-height: 1.3; margin: 0 0 var(--space-xs) 0; }
  .article-desc { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.4; margin: 0 0 var(--space-xs) 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .article-source { font-size: 0.72rem; color: var(--color-text-muted); opacity: 0.7; }
  .empty-state { color: var(--color-text-muted); font-style: italic; }

  /* Recommender drawer */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    pointer-events: none;
  }
  .drawer.open { pointer-events: auto; }

  .drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 0.25s;
  }
  .drawer.open .drawer-backdrop { opacity: 1; }

  .drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 540px;
    max-width: 100vw;
    background: var(--color-bg, #fff);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
  }
  .drawer.open .drawer-panel { transform: translateX(0); }

  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .drawer-title { font-size: 0.9rem; font-weight: 600; color: var(--color-heading); }
  .drawer-close {
    background: none;
    border: none;
    font-size: 1rem;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0.25rem;
    line-height: 1;
    border-radius: 4px;
  }
  .drawer-close:hover { color: var(--color-text); background: var(--color-surface-raised, #f3f4f6); }

  .drawer-iframe {
    flex: 1;
    width: 100%;
    border: none;
    display: block;
  }
</style>
