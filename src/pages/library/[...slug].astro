---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const books = await getCollection('library');
  return books.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const statusLabel: Record<string, string> = {
  'reading': 'Currently reading',
  'read': 'Read',
  'to-read': 'To read',
};
---

<PostLayout
  title={entry.data.title}
  date={entry.data.date}
  updated={entry.data.updated}
  maturity={entry.data.maturity}
  tags={entry.data.tags}
  description={entry.data.description}
  collection="library"
  slug={entry.id}
  ai={entry.data.ai}
  triples={entry.data.triples}
>
  <div class="book-header">
    {entry.data.cover && (
      <img src={entry.data.cover} alt="" class="book-detail-cover" />
    )}
    <div class="book-header-info">
      <p class="book-author">by {entry.data.author}</p>
      <span class="book-reading-status">{statusLabel[entry.data.status]}</span>
      {entry.data.file && (
        <a href={entry.data.file} class="book-pdf-link" target="_blank" rel="noopener">Annotated PDF</a>
      )}
    </div>
  </div>
  <Content />

  {(entry.data.reason || entry.data.rating || entry.data.review) && (
    <dl class="book-meta-list">
      {entry.data.reason && (
        <>
          <dt>Why I picked it up</dt>
          <dd>{entry.data.reason}</dd>
        </>
      )}
      {entry.data.rating && (
        <>
          <dt>Rating</dt>
          <dd>{entry.data.rating}</dd>
        </>
      )}
      {entry.data.review && (
        <>
          <dt>Review</dt>
          <dd>{entry.data.review}</dd>
        </>
      )}
    </dl>
  )}
</PostLayout>

<style>
  .book-header {
    display: flex;
    gap: var(--space-lg);
    margin-block-end: var(--space-xl);
  }
  .book-detail-cover {
    width: 120px;
    height: auto;
    border-radius: 0.25rem;
    box-shadow: 0 2px 8px var(--color-shadow);
    flex-shrink: 0;
  }
  .book-header-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  .book-author {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .book-reading-status {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
  }
  .book-pdf-link {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }
  .book-pdf-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .book-meta-list {
    margin-block-start: var(--space-2xl);
    border-top: 1px solid var(--color-border);
    padding-block-start: var(--space-lg);
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-xs) var(--space-lg);
  }
  .book-meta-list dt {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    padding-block-start: 0.15em;
  }
  .book-meta-list dd {
    font-size: 0.85rem;
    color: var(--color-text);
    margin: 0;
  }
</style>
