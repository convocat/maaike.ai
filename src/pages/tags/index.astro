---
import PageLayout from '../../layouts/PageLayout.astro';
import { getAllContent, getUniqueTags } from '../../utils/collections';

const allContent = await getAllContent();
const tags = getUniqueTags(allContent);

const tagCounts = new Map<string, number>();
for (const tag of tags) {
  tagCounts.set(tag, allContent.filter((e) => e.data.tags.includes(tag)).length);
}
---

<PageLayout title="Tags — Maai & AI">
  <h1>Tags</h1>
  <p class="section-description">Browse content by topic.</p>

  <ul class="tag-cloud">
    {tags.map((tag) => (
      <li>
        <a href={`/tags/${tag}`} class="tag-link">
          {tag}
          <span class="tag-count">{tagCounts.get(tag)}</span>
        </a>
      </li>
    ))}
  </ul>
</PageLayout>

<style>
  h1 { margin-block-end: var(--space-xs); }
  .section-description {
    color: var(--color-text-muted);
    margin-block-end: var(--space-xl);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.4em 0.8em;
    border-radius: 1em;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    text-decoration: none;
    font-size: 0.95rem;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .tag-link:hover {
    background: var(--color-accent);
    color: #FFFFFF;
  }

  .tag-count {
    font-size: 0.8rem;
    opacity: 0.7;
  }
</style>
