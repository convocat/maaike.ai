---
import PageLayout from './PageLayout.astro';
import TagList from '../components/TagList.astro';
import WikiLinkPreview from '../components/WikiLinkPreview.astro';
import CollectionIcon from '../components/CollectionIcon.astro';
import PostSidebar from '../components/PostSidebar.astro';


interface Props {
  title: string;
  date: Date;
  updated?: Date;
  maturity: 'draft' | 'developing' | 'solid' | 'complete';
  tags: string[];
  description?: string;
  collection: string;
  slug: string;
  url?: string;
  ai?: '100% Maai' | 'assisted' | 'co-created' | 'generated';
}

const { title, date, updated, maturity, tags, description, collection, slug, url, ai } = Astro.props;

const ogImage = `/images/og-${collection}.png`;
const postUrl = `https://maaike.ai/${collection}/${slug}/`;

const aiLabels: Record<string, { label: string; description: string }> = {
  '100% Maai': { label: '100% Maai', description: 'Fully written by me.' },
  assisted: { label: 'AI-assisted', description: 'My ideas and structure, AI helped refine.' },
  'co-created': { label: 'Co-created with AI', description: 'Written by AI based on my ideas and direction.' },
  generated: { label: 'AI-generated', description: 'Fully generated by AI, reviewed by me.' },
};

const stages = [
  { key: 'draft', emoji: '🌱', label: 'Seedling' },
  { key: 'developing', emoji: '🌿', label: 'Sprout' },
  { key: 'solid', emoji: '🪴', label: 'Plant' },
  { key: 'complete', emoji: '🌳', label: 'Tree' },
];

const currentIndex = stages.findIndex((s) => s.key === maturity);

const formattedDate = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);

const formattedUpdated = updated
  ? new Intl.DateTimeFormat('en-GB', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(updated)
  : null;
---

<PageLayout title={title} description={description} ogImage={ogImage}>
  <div class="post-with-sidebar">
    <article class="post">
      <header class="post-header">
        {tags.length > 0 && <TagList tags={tags} />}
        <div class="post-collection-label">
          <CollectionIcon collection={collection} size={16} />
          <span>{collection.replace(/-/g, ' ')}</span>
        </div>
        <h1>{title}</h1>
        {url && (
          <a href={url} class="external-link" target="_blank" rel="noopener noreferrer">
            {new URL(url).hostname.replace('www.', '')} ↗
          </a>
        )}
        <div class="post-meta-line">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {formattedUpdated && (
            <>
              <span class="post-meta-sep">&middot;</span>
              <span class="post-updated">Tended {formattedUpdated}</span>
            </>
          )}
        </div>
        <div class="maturity-track" role="img" aria-label={`Maturity: ${stages[currentIndex].label}`}>
          {stages.map((stage, i) => (
            <div class:list={['maturity-step', { 'is-reached': i <= currentIndex, 'is-current': i === currentIndex }]}>
              <span class="maturity-step-emoji">{stage.emoji}</span>
              {i < stages.length - 1 && (
                <span class:list={['maturity-step-line', { 'is-filled': i < currentIndex }]} aria-hidden="true" />
              )}
            </div>
          ))}
        </div>
      </header>

      {ai && aiLabels[ai] && (
        <aside class="ai-box">
          <div class="ai-header">
            <span class="ai-icon">🤖</span>
            <span class="ai-label">{aiLabels[ai].label}</span>
          </div>
          <p>{aiLabels[ai].description}</p>
        </aside>
      )}

      <div class="prose">
        <slot />
      </div>

      <footer class="post-footer">
      </footer>
    </article>

    <aside class="post-sidebar">
      <PostSidebar slug={slug} tags={tags} collection={collection} title={title} postUrl={postUrl} />
    </aside>
  </div>
  <WikiLinkPreview />
</PageLayout>

<style>
  .post-with-sidebar {
    display: grid;
    grid-template-columns: 1fr 14rem;
    gap: var(--space-xl);
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .post {
    min-width: 0;
  }

  .post-sidebar {
    padding-block-start: var(--space-3xl);
    opacity: 0.85;
  }

  @media (max-width: 68rem) {
    .post-with-sidebar {
      grid-template-columns: 1fr;
    }

    .post-sidebar {
      padding-block-start: 0;
      margin-block-start: var(--space-xl);
      padding-block-start: var(--space-xl);
      border-top: 1px solid var(--color-border);
    }
  }

  .post-header {
    margin-block-end: var(--space-3xl);
    padding-block-end: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .post-collection-label {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.8rem;
    text-transform: capitalize;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    margin-block-start: var(--space-sm);
  }

  .post-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    line-height: 1.2;
    margin-block: var(--space-md) var(--space-md);
  }

  .external-link {
    display: inline-block;
    font-size: 0.95rem;
    color: var(--color-accent);
    text-decoration: none;
    margin-block-end: var(--space-sm);
  }

  .external-link:hover {
    text-decoration: underline;
  }

  .post-meta-line {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .post-meta-sep {
    opacity: 0.4;
  }

  .maturity-track {
    display: flex;
    align-items: center;
    gap: 0;
    margin-block-start: var(--space-md);
  }

  .maturity-step {
    display: flex;
    align-items: center;
  }

  .maturity-step-emoji {
    font-size: 1.25rem;
    opacity: 0.25;
    transition: opacity var(--transition-base);
  }

  .maturity-step.is-reached .maturity-step-emoji {
    opacity: 1;
  }

  .maturity-step.is-current .maturity-step-emoji {
    font-size: 1.5rem;
  }

  .maturity-step-line {
    display: inline-block;
    width: 2rem;
    height: 2px;
    background: var(--color-border);
    margin-inline: 0.4rem;
  }

  .maturity-step-line.is-filled {
    background: linear-gradient(to right, var(--color-accent), var(--color-accent-2));
    opacity: 0.6;
  }

  .ai-box {
    background: var(--color-tag-bg);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 0.5rem 0.5rem 0;
    padding: var(--space-md) var(--space-lg);
    margin-block-end: var(--space-xl);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .ai-header {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-block-end: var(--space-xs);
  }
  .ai-icon {
    font-size: 1rem;
  }
  .ai-label {
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    color: #C00060;
  }
  .ai-box p {
    margin: 0;
    color: var(--color-text);
  }

  .post-footer {
    margin-block-start: var(--space-3xl);
    padding-block-start: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }
</style>
