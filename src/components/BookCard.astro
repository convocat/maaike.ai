---
import MaturityBadge from './MaturityBadge.astro';

interface Props {
  title: string;
  href: string;
  author: string;
  cover?: string;
  status: 'reading' | 'read' | 'to-read' | 'abandoned';
  maturity: 'draft' | 'developing' | 'solid' | 'complete';
  tags?: string[];
  description?: string;
  date?: string;
  updated?: string;
}

const { title, href, author, cover, status, maturity, tags, description, date, updated } = Astro.props;

const statusLabel: Record<string, string> = {
  'reading': 'Reading',
  'read': 'Read',
  'to-read': 'To read',
};
const statusClass: Record<string, string> = {
  'reading': 'status-reading',
  'read': 'status-read',
  'to-read': 'status-toread',
};
---

<a
  href={href}
  class="card book-card"
  data-maturity={maturity}
  data-tags={tags?.join(',') ?? ''}
  data-date={date ?? ''}
  data-updated={updated ?? ''}
>
  {cover ? (
    <img src={cover} alt="" class="book-cover" loading="lazy" />
  ) : (
    <div class="book-cover-placeholder">
      <span>{title.charAt(0)}</span>
    </div>
  )}
  <div class="book-info">
    <div class="book-meta">
      <MaturityBadge maturity={maturity} />
      <span class:list={['book-status', statusClass[status]]}>{statusLabel[status]}</span>
    </div>
    <h3 class="book-title">{title}</h3>
    <span class="book-author">{author}</span>
    {description && <p class="book-desc">{description}</p>}
  </div>
</a>

<style is:global>
  .book-card {
    display: flex;
    gap: var(--space-md);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .book-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--color-shadow);
    border-color: transparent;
  }

  .book-cover {
    width: 80px;
    height: 120px;
    object-fit: cover;
    border-radius: 0.25rem;
    flex-shrink: 0;
  }
  .book-cover-placeholder {
    width: 80px;
    height: 120px;
    border-radius: 0.25rem;
    flex-shrink: 0;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    font-family: var(--font-heading);
  }

  .book-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .book-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-block-end: var(--space-xs);
  }

  .book-status {
    font-size: 0.7rem;
    padding: 0.1em 0.5em;
    border-radius: 1em;
    font-weight: 500;
  }
  .status-reading {
    background: #dbeafe;
    color: #1e40af;
  }
  .status-read {
    background: #dcfce7;
    color: #166534;
  }
  .status-toread {
    background: #f3f4f6;
    color: #6b7280;
  }
  :root[data-theme="dark"] .status-reading {
    background: #1e3a5f;
    color: #93c5fd;
  }
  :root[data-theme="dark"] .status-read {
    background: #14532d;
    color: #86efac;
  }
  :root[data-theme="dark"] .status-toread {
    background: #374151;
    color: #9ca3af;
  }

  .book-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.3;
    margin: 0;
  }

  .book-author {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-block-start: 0.15em;
  }

  .book-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-block-start: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
