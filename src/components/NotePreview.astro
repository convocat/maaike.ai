---
import MaturityBadge from './MaturityBadge.astro';

interface Props {
  title: string;
  href: string;
  date: Date;
  updated?: Date;
  maturity: 'draft' | 'developing' | 'solid' | 'complete' | 'compost';
  description?: string;
}

const { title, href, date, updated, maturity, description } = Astro.props;

const dateFmt = new Intl.DateTimeFormat('en-GB', { month: 'short', day: 'numeric' });
const displayDate = updated ?? date;
const dateLabel = updated ? 'Tended' : 'Planted';
const formattedDate = dateFmt.format(displayDate);
---

<a href={href} class="note-preview">
  <div class="note-preview-top">
    <MaturityBadge maturity={maturity} />
    <time datetime={displayDate.toISOString()}><span class="note-date-label">{dateLabel}</span> {formattedDate}</time>
  </div>
  <h3 class="note-preview-title">{title}</h3>
  {description && <p class="note-preview-desc">{description}</p>}
</a>

<style is:global>
  .note-preview {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    min-height: 10rem;
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .note-preview:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--color-shadow);
    border-color: transparent;
  }

  .note-preview-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-block-end: var(--space-xs);
  }

  .note-preview-top time {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .note-date-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    opacity: 0.6;
    margin-inline-end: 0.3em;
  }

  .note-preview-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-heading);
    line-height: 1.3;
    margin: 0;
  }

  .note-preview-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-block-start: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
</style>
