---
interface Props {
  maturity?: 'draft' | 'developing' | 'solid' | 'complete';
}

const { maturity } = Astro.props;

const config: Record<string, { icon: string; label: string }> = {
  draft:      { icon: '\u{1F331}', label: 'Seedling' },
  developing: { icon: '\u{1F33F}', label: 'Sprout' },
  solid:      { icon: '\u{1FAB4}', label: 'Plant' },
  complete:   { icon: '\u{1F333}', label: 'Tree' },
};

const entry = maturity ? config[maturity] : null;
---

{entry && <span class="maturity-icon" role="img" aria-label={entry.label} title={entry.label}>{entry.icon}</span>}

<style>
  .maturity-icon {
    font-size: 0.85em;
    line-height: 1;
    flex-shrink: 0;
  }
</style>
