---
import settings from '../data/settings.json';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-webring" aria-label="IndieWeb Webring">
      <a href="https://xn--sr8hvo.ws/previous" rel="noopener">&larr;</a>
      <a href="https://xn--sr8hvo.ws" rel="noopener" class="webring-badge">🕸💍</a>
      <a href="https://xn--sr8hvo.ws/next" rel="noopener">&rarr;</a>
    </div>
    <p class="footer-copy">&copy; {year} {settings.siteTitle}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-lg);
    margin-block-start: var(--space-3xl);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-webring {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .footer-webring a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-webring a:hover {
    color: var(--color-accent);
  }

  .webring-badge {
    font-size: 1rem;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
