---
import { getBacklinks } from '../utils/backlinks';
import { getRelatedPosts } from '../utils/collections';
import CollectionIcon from './CollectionIcon.astro';

interface Props {
  slug: string;
  tags: string[];
  collection: string;
  title: string;
}

const { slug, tags, collection, title } = Astro.props;

const backlinks = await getBacklinks(slug);
const relatedPosts = await getRelatedPosts(slug, tags, collection);
---

<div class="sidebar-content">
  {tags.length > 0 && (
    <section class="sidebar-section">
      <h3 class="sidebar-heading">Tags</h3>
      <ul class="sidebar-tags">
        {tags.map((tag) => (
          <li><a href={`/tags/${tag}`} class="sidebar-tag">{tag}</a></li>
        ))}
      </ul>
    </section>
  )}

  {backlinks.length > 0 && (
    <section class="sidebar-section">
      <h3 class="sidebar-heading">Linked from</h3>
      <ul class="sidebar-links">
        {backlinks.map(({ title: blTitle, href }) => (
          <li><a href={href}>{blTitle}</a></li>
        ))}
      </ul>
    </section>
  )}

  {relatedPosts.length > 0 && (
    <section class="sidebar-section">
      <h3 class="sidebar-heading">Related</h3>
      <ul class="sidebar-links">
        {relatedPosts.map(({ title: rpTitle, href, collection: coll }) => (
          <li>
            <a href={href}>
              <CollectionIcon collection={coll} size={14} />
              <span>{rpTitle}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</div>

<style>
  .sidebar-content {
    position: sticky;
    top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    font-size: 0.85rem;
  }

  .sidebar-heading {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-block-end: var(--space-xs);
  }

  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-tag {
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.15em 0.55em;
    border-radius: 1em;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .sidebar-tag:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .sidebar-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .sidebar-links a {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    line-height: 1.4;
  }

  .sidebar-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 68rem) {
    .sidebar-content {
      position: static;
    }

    .sidebar-links {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-sm);
    }
  }
</style>
