---
import { getBacklinks } from '../utils/backlinks';
import { getRelatedPosts, getAllContent } from '../utils/collections';
import { getSuggestedBooks } from '../utils/recommender';
import CollectionIcon from './CollectionIcon.astro';
interface Props {
  slug: string;
  tags: string[];
  collection: string;
  title: string;
  postUrl: string;
  hub?: boolean;
  develops?: string;
}

const { slug, tags, collection, title, postUrl, hub, develops } = Astro.props;

const isHub = hub === true;
const backlinks = await getBacklinks(slug);
const relatedPosts = await getRelatedPosts(slug, tags, collection);
const suggestedBooks = await getSuggestedBooks(collection, slug, tags);

// Resolve the hub post when this file develops one
let hubPost: { title: string; href: string; collection: string } | null = null;
if (develops) {
  const allContent = await getAllContent();
  const found = allContent.find((e) => e.id === develops);
  if (found) {
    hubPost = { title: found.data.title, href: `/${found.collection}/${found.id}`, collection: found.collection };
  }
}
---

<div class="sidebar-content">
  {hubPost && (
    <section class="sidebar-section">
      <h3 class="sidebar-heading">Part of</h3>
      <ul class="sidebar-links">
        <li>
          <a href={hubPost.href}>
            <CollectionIcon collection={hubPost.collection} size={14} />
            <span>{hubPost.title}</span>
          </a>
        </li>
      </ul>
    </section>
  )}

  {backlinks.length > 0 && (
    <section class="sidebar-section">
      <h3 class="sidebar-heading">{isHub ? 'Project files' : 'Linked from'}</h3>
      <ul class="sidebar-links">
        {backlinks.map(({ title: blTitle, href, collection: coll }) => (
          <li>
            <a href={href}>
              <CollectionIcon collection={coll} size={14} />
              <span>{blTitle}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {!isHub && relatedPosts.length > 0 && (
    <section class="sidebar-section">
      <h3 class="sidebar-heading">Related</h3>
      <ul class="sidebar-links">
        {relatedPosts.map(({ title: rpTitle, href, collection: coll }) => (
          <li>
            <a href={href}>
              <CollectionIcon collection={coll} size={14} />
              <span>{rpTitle}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {suggestedBooks.length > 0 && (
    <section class="sidebar-section">
      <h3 class="sidebar-heading">Suggested reading</h3>
      <ul class="sidebar-books">
        {suggestedBooks.map(({ title: bookTitle, author, href, cover }) => (
          <li>
            <a href={href} class="sidebar-book">
              {cover ? (
                <img src={cover} alt="" class="sidebar-book-cover" loading="lazy" />
              ) : (
                <div class="sidebar-book-placeholder">{bookTitle.charAt(0)}</div>
              )}
              <div class="sidebar-book-info">
                <span class="sidebar-book-title">{bookTitle}</span>
                <span class="sidebar-book-author">{author}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}


</div>

<style>
  .sidebar-content {
    position: sticky;
    top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    font-size: 0.85rem;
  }

  .sidebar-heading {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-block-end: var(--space-xs);
  }

  .sidebar-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .sidebar-links a {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    line-height: 1.4;
  }

  .sidebar-links a:hover {
    color: var(--color-accent);
  }

  .sidebar-books {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .sidebar-book {
    display: flex;
    align-items: flex-start;
    gap: var(--space-xs);
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .sidebar-book:hover {
    color: var(--color-accent);
  }

  .sidebar-book-cover {
    width: 28px;
    height: 40px;
    object-fit: cover;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .sidebar-book-placeholder {
    width: 28px;
    height: 40px;
    background: var(--color-tag-bg);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .sidebar-book-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }

  .sidebar-book-title {
    font-size: 0.78rem;
    line-height: 1.3;
  }

  .sidebar-book-author {
    font-size: 0.68rem;
    opacity: 0.7;
  }

  @media (max-width: 68rem) {
    .sidebar-content {
      position: static;
    }

    .sidebar-links {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-sm);
    }

  }
</style>
