---
interface Props {
  collection: string;
  size?: number;
}

const { collection, size = 24 } = Astro.props;

// SVG inner content per collection (hardcoded, safe for set:html)
const icons: Record<string, string> = {
  articles: `
    <path d="M6 2 L15 2 L20 7 L20 22 L6 22 Z" />
    <path d="M15 2 L15 7 L20 7" />
    <line x1="9" y1="11" x2="17" y2="11" />
    <line x1="9" y1="14" x2="17" y2="14" />
    <line x1="9" y1="17" x2="14" y2="17" />`,
  'field-notes': `
    <line x1="10" y1="2" x2="10" y2="9" />
    <line x1="14" y1="2" x2="14" y2="9" />
    <line x1="9" y1="2" x2="15" y2="2" />
    <path d="M10 9 L4 20 C3.5 21, 4 22, 5 22 L19 22 C20 22, 20.5 21, 20 20 L14 9" />
    <path d="M6.5 17 L17.5 17" />
    <circle cx="10" cy="19" r="0.7" />
    <circle cx="13" cy="18.5" r="0.5" />
    <circle cx="11.5" cy="15.5" r="0.4" />`,
  sparks: `
    <path d="M12 2 C12.5 8, 13 11, 22 12 C13 13, 12.5 16, 12 22 C11.5 16, 11 13, 2 12 C11 11, 11.5 8, 12 2 Z" />`,
  weblinks: `
    <path d="M2 12 L22 3 L16 21 L12 14 Z" />
    <line x1="22" y1="3" x2="12" y2="14" />`,
  videos: `
    <path d="M1 12 C4 8.5, 8 6, 12 6 C16 6, 20 8.5, 23 12 C20 15.5, 16 18, 12 18 C8 18, 4 15.5, 1 12 Z" />
    <circle cx="12" cy="12" r="4.5" />
    <circle cx="12" cy="12" r="2.5" class="icon-fill" />`,
  library: `
    <line x1="3" y1="20" x2="21" y2="20" />
    <rect x="6" y="6" width="3" height="14" rx="0.3" />
    <rect x="9.5" y="9" width="2.5" height="11" rx="0.3" />
    <rect x="12.5" y="5" width="3.5" height="15" rx="0.3" />
    <rect x="16.5" y="7" width="3" height="13" rx="0.3" />`,
  principles: `
    <circle cx="12" cy="12" r="10" />
    <circle cx="12" cy="12" r="7.5" />
    <line x1="12" y1="2" x2="12" y2="4" />
    <line x1="12" y1="20" x2="12" y2="22" />
    <line x1="2" y1="12" x2="4" y2="12" />
    <line x1="20" y1="12" x2="22" y2="12" />
    <line x1="5.1" y1="5.1" x2="6.5" y2="6.5" />
    <line x1="18.9" y1="5.1" x2="17.5" y2="6.5" />
    <line x1="5.1" y1="18.9" x2="6.5" y2="17.5" />
    <line x1="18.9" y1="18.9" x2="17.5" y2="17.5" />
    <path d="M12 4.5 L10 12 L14 12 Z" class="icon-fill" />
    <path d="M12 19.5 L14 12 L10 12 Z" />
    <circle cx="12" cy="12" r="1.2" />`,
};

const svgContent = icons[collection];
---

{svgContent && (
  <svg
    class={`collection-icon collection-icon--${collection}`}
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke-width="1"
    stroke-linecap="round"
    stroke-linejoin="round"
    filter="url(#sketchy)"
    aria-hidden="true"
    set:html={svgContent}
  />
)}

<style is:global>
  .collection-icon {
    display: inline-block;
    overflow: visible;
    flex-shrink: 0;
    vertical-align: middle;
  }

  /* Light mode stroke colors */
  .collection-icon--articles { stroke: #9e7c6b; }
  .collection-icon--field-notes { stroke: #7a9a7e; }
  .collection-icon--sparks { stroke: #c4956a; }
  .collection-icon--weblinks { stroke: #a08872; }
  .collection-icon--videos { stroke: #8e7a8a; }
  .collection-icon--library { stroke: #7d7068; }
  .collection-icon--principles { stroke: #7a8a6e; }

  /* Filled elements (pupil, compass needle) inherit stroke color */
  .collection-icon--videos .icon-fill { fill: #8e7a8a; }
  .collection-icon--principles .icon-fill { fill: #7a8a6e; }

  /* Dark mode — brighter variants for contrast */
  :root[data-theme="dark"] .collection-icon--articles { stroke: #c4a38f; }
  :root[data-theme="dark"] .collection-icon--field-notes { stroke: #a3c4a7; }
  :root[data-theme="dark"] .collection-icon--sparks { stroke: #ddb892; }
  :root[data-theme="dark"] .collection-icon--weblinks { stroke: #c4ad98; }
  :root[data-theme="dark"] .collection-icon--videos { stroke: #b5a3b2; }
  :root[data-theme="dark"] .collection-icon--library { stroke: #a89e96; }
  :root[data-theme="dark"] .collection-icon--principles { stroke: #a3b498; }

  :root[data-theme="dark"] .collection-icon--videos .icon-fill { fill: #b5a3b2; }
  :root[data-theme="dark"] .collection-icon--principles .icon-fill { fill: #a3b498; }
</style>
