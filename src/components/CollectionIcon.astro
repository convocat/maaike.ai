---
interface Props {
  collection: string;
  size?: number;
}

const { collection, size = 24 } = Astro.props;

// SVG inner content per collection (hardcoded, safe for set:html)
const icons: Record<string, string> = {
  articles: `
    <path d="M6 2 L15 2 L20 7 L20 22 L6 22 Z" />
    <path d="M15 2 L15 7 L20 7" />
    <line x1="9" y1="11" x2="17" y2="11" />
    <line x1="9" y1="14" x2="17" y2="14" />
    <line x1="9" y1="17" x2="14" y2="17" />`,
  'field-notes': `
    <path d="M5 4 L5 22 L19 22 L19 4 Z" />
    <path d="M10 4 L10 2.5 L14 2.5 L14 4" />
    <line x1="7" y1="4" x2="17" y2="4" />
    <path d="M6.5 6 L6.5 20.5 L17.5 20.5 L17.5 6 Z" />
    <rect x="10" y="9" width="2" height="2" />
    <rect x="10" y="13" width="2" height="2" />
    <rect x="10" y="17" width="2" height="2" />`,
  seeds: `
    <path d="M12 22 C12 22, 12 16, 12 14" />
    <path d="M12 14 C8 14, 5 10, 7 6 C9 2, 12 2, 12 2 C12 2, 15 2, 17 6 C19 10, 16 14, 12 14 Z" />
    <path d="M12 6 C12 6, 10 9, 12 14" />`,
  weblinks: `
    <path d="M2 12 L22 3 L16 21 L12 14 Z" />
    <line x1="22" y1="3" x2="12" y2="14" />`,
  videos: `
    <path d="M1 12 C4 8.5, 8 6, 12 6 C16 6, 20 8.5, 23 12 C20 15.5, 16 18, 12 18 C8 18, 4 15.5, 1 12 Z" />
    <circle cx="12" cy="12" r="4.5" />
    <circle cx="12" cy="12" r="2.5" class="icon-fill" />`,
  library: `
    <line x1="3" y1="20" x2="21" y2="20" />
    <rect x="6" y="6" width="3" height="14" rx="0.3" />
    <rect x="9.5" y="9" width="2.5" height="11" rx="0.3" />
    <rect x="12.5" y="5" width="3.5" height="15" rx="0.3" />
    <rect x="16.5" y="7" width="3" height="13" rx="0.3" />`,
  experiments: `
    <path d="M10 2 L10 8 L5 18 C4 20, 5 22, 7 22 L17 22 C19 22, 20 20, 19 18 L14 8 L14 2" />
    <line x1="8" y1="2" x2="16" y2="2" />
    <line x1="10" y1="8" x2="14" y2="8" />
    <circle cx="10" cy="16" r="1" class="icon-fill" />
    <circle cx="13" cy="18" r="0.7" class="icon-fill" />
    <circle cx="15" cy="15" r="0.5" class="icon-fill" />`,
};

const svgContent = icons[collection];
---

{svgContent && (
  <svg
    class={`collection-icon collection-icon--${collection}`}
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke-width="1"
    stroke-linecap="round"
    stroke-linejoin="round"
    filter="url(#sketchy)"
    aria-hidden="true"
    set:html={svgContent}
  />
)}

<style is:global>
  .collection-icon {
    display: inline-block;
    overflow: visible;
    flex-shrink: 0;
    vertical-align: middle;
  }

  /* Light mode stroke colors (WCAG AA ≥3:1 on white) */
  .collection-icon--articles { stroke: #7A5A48; }
  .collection-icon--field-notes { stroke: #4A7A50; }
  .collection-icon--seeds { stroke: #A07030; }
  .collection-icon--weblinks { stroke: #7A6048; }
  .collection-icon--videos { stroke: #6E4E68; }
  .collection-icon--library { stroke: #5A4E44; }
  .collection-icon--experiments { stroke: #3A7080; }

  /* Filled elements (pupil, compass needle, bubbles) inherit stroke color */
  .collection-icon--videos .icon-fill { fill: #6E4E68; }
  .collection-icon--experiments .icon-fill { fill: #3A7080; }
  /* Dark mode (WCAG AA ≥3:1 on #111) */
  :root[data-theme="dark"] .collection-icon--articles { stroke: #D4A88E; }
  :root[data-theme="dark"] .collection-icon--field-notes { stroke: #8ECF94; }
  :root[data-theme="dark"] .collection-icon--seeds { stroke: #E8C07A; }
  :root[data-theme="dark"] .collection-icon--weblinks { stroke: #D4B89E; }
  :root[data-theme="dark"] .collection-icon--videos { stroke: #C9A8C4; }
  :root[data-theme="dark"] .collection-icon--library { stroke: #BDB0A6; }
  :root[data-theme="dark"] .collection-icon--experiments { stroke: #7ECCD6; }

  :root[data-theme="dark"] .collection-icon--videos .icon-fill { fill: #C9A8C4; }
  :root[data-theme="dark"] .collection-icon--experiments .icon-fill { fill: #7ECCD6; }
</style>
