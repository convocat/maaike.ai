---
interface Props {
  collection: string;
  size?: number;
}

const { collection, size = 24 } = Astro.props;

const iconMap: Record<string, string> = {
  articles: '/images/icons/doc.svg',
  'field-notes': '/images/icons/note.svg',
  seeds: '/images/icons/bulb.svg',
  weblinks: '/images/icons/globe.svg',
  videos: '/images/icons/play.svg',
  library: '/images/icons/bookmark.svg',
  experiments: '/images/icons/flask.svg',
  jottings: '/images/icons/pencil.svg',
  projects: '/images/icons/rocket.svg',
  files: '/images/icons/folder.svg',
  artefacts: '/images/icons/gem.svg',
};

const iconSrc = iconMap[collection];
---

{iconSrc && (
  <img
    class={`collection-icon collection-icon--${collection}`}
    src={iconSrc}
    width={size}
    height={size}
    alt=""
    aria-hidden="true"
    loading="lazy"
  />
)}

<style is:global>
  .collection-icon {
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
</style>
