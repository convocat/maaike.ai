---
interface Category {
  emoji: string;
  label: string;
  tags: string[];
}

interface StatusOption {
  key: string;
  label: string;
}

interface Props {
  tags: string[];
  categories?: Category[];
  statusOptions?: StatusOption[];
}

const { tags, categories, statusOptions } = Astro.props;

const stages = [
  { key: 'draft', emoji: '🌱', label: 'Seedling' },
  { key: 'developing', emoji: '🌿', label: 'Sprout' },
  { key: 'solid', emoji: '🪴', label: 'Plant' },
  { key: 'complete', emoji: '🌳', label: 'Tree' },
];
---

<div class="filter-bar" id="filter-bar">
  <div class="filter-row">
    <div class="filter-group">
      <button class="filter-btn active" data-filter="all" aria-pressed="true">All</button>
      {stages.map((s) => (
        <button
          class="filter-btn maturity-btn"
          data-filter={s.key}
          aria-pressed="false"
          aria-label={`Filter by ${s.label}`}
          title={s.label}
        >
          {s.emoji}
        </button>
      ))}
    </div>

    {statusOptions && statusOptions.length > 0 ? (
      <div class="sort-group">
        {statusOptions.map((opt) => (
          <button class="sort-btn status-btn" data-status={opt.key} aria-pressed="false">
            {opt.label}
          </button>
        ))}
      </div>
    ) : (
      <div class="sort-group">
        <span class="sort-label">Sort:</span>
        <button class="sort-btn active" data-sort="date" aria-pressed="true">Planted ↓</button>
        <button class="sort-btn" data-sort="updated" aria-pressed="false">Last tended</button>
      </div>
    )}
  </div>

  {categories && categories.length > 0 ? (
    <div class="filter-row category-row">
      {categories.map((cat) => (
        <button
          class="category-btn"
          data-tags={cat.tags.join(',')}
          aria-pressed="false"
          title={cat.label}
        >
          <span class="category-emoji">{cat.emoji}</span>
          <span class="category-label">{cat.label}</span>
        </button>
      ))}
    </div>
  ) : tags.length > 0 && (
    <div class="filter-row tag-row">
      {tags.map((tag, i) => (
        <button class="tag-chip" data-tag={tag} aria-pressed="false" hidden={i >= 8 || undefined}>{tag}</button>
      ))}
      {tags.length > 8 && (
        <button class="tag-chip tag-toggle" id="tag-toggle">+{tags.length - 8} more</button>
      )}
    </div>
  )}
</div>

<script>
  (() => {
    const bar = document.getElementById('filter-bar');
    if (!bar) return;

    const cards = () => [...document.querySelectorAll<HTMLElement>('.card')];
    const activeMaturity = new Set<string>();
    const activeCategories = new Map<Element, Set<string>>();
    let currentSort = 'date';
    let activeStatus: string | null = null;

    const allBtn = bar.querySelector<HTMLButtonElement>('[data-filter="all"]')!;
    const maturityBtns = bar.querySelectorAll<HTMLButtonElement>('.maturity-btn');
    const sortBtns = bar.querySelectorAll<HTMLButtonElement>('.sort-btn:not(.status-btn)');
    const statusBtns = bar.querySelectorAll<HTMLButtonElement>('.status-btn');
    const categoryBtns = bar.querySelectorAll<HTMLButtonElement>('.category-btn');
    const tagChips = bar.querySelectorAll<HTMLButtonElement>('.tag-chip[data-tag]');

    function getActiveTags(): Set<string> {
      const all = new Set<string>();
      activeCategories.forEach((tags) => tags.forEach((t) => all.add(t)));
      tagChips.forEach((chip) => {
        if (chip.classList.contains('active')) all.add(chip.dataset.tag!);
      });
      return all;
    }

    function applyFilters() {
      const activeTags = getActiveTags();
      for (const card of cards()) {
        const m = card.dataset.maturity ?? '';
        const t = (card.dataset.tags ?? '').split(',').filter(Boolean);
        const s = card.dataset.status ?? '';
        const matchesMaturity = activeMaturity.size === 0 || activeMaturity.has(m);
        const matchesTags = activeTags.size === 0 || t.some((tag) => activeTags.has(tag));
        const matchesStatus = activeStatus === null || s === activeStatus;
        card.style.display = matchesMaturity && matchesTags && matchesStatus ? '' : 'none';
      }
    }

    function applySort() {
      const byParent = new Map<Element, HTMLElement[]>();
      for (const card of cards()) {
        const parent = card.parentElement!;
        if (!byParent.has(parent)) byParent.set(parent, []);
        byParent.get(parent)!.push(card);
      }
      byParent.forEach((group, parent) => {
        const sorted = [...group].sort((a, b) => {
          const key = currentSort === 'updated' ? 'updated' : 'date';
          const da = new Date(a.dataset[key] ?? '').getTime();
          const db = new Date(b.dataset[key] ?? '').getTime();
          return db - da;
        });
        for (const card of sorted) parent.appendChild(card);
      });
    }

    function syncAllBtn() {
      const isAll = activeMaturity.size === 0;
      allBtn.classList.toggle('active', isAll);
      allBtn.setAttribute('aria-pressed', String(isAll));
    }

    allBtn.addEventListener('click', () => {
      activeMaturity.clear();
      maturityBtns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
      syncAllBtn();
      applyFilters();
    });

    maturityBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.filter!;
        if (activeMaturity.has(key)) {
          activeMaturity.delete(key);
          btn.classList.remove('active');
          btn.setAttribute('aria-pressed', 'false');
        } else {
          activeMaturity.add(key);
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
        }
        syncAllBtn();
        applyFilters();
      });
    });

    statusBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.status!;
        if (activeStatus === key) {
          // deactivate
          activeStatus = null;
          btn.classList.remove('active');
          btn.setAttribute('aria-pressed', 'false');
        } else {
          activeStatus = key;
          statusBtns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
        }
        applyFilters();
      });
    });

    categoryBtns.forEach((btn) => {
      const tagSet = new Set((btn.dataset.tags ?? '').split(',').filter(Boolean));
      btn.addEventListener('click', () => {
        if (activeCategories.has(btn)) {
          activeCategories.delete(btn);
          btn.classList.remove('active');
          btn.setAttribute('aria-pressed', 'false');
        } else {
          activeCategories.set(btn, tagSet);
          btn.classList.add('active');
          btn.setAttribute('aria-pressed', 'true');
        }
        applyFilters();
      });
    });

    tagChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('active');
        const pressed = chip.classList.contains('active');
        chip.setAttribute('aria-pressed', String(pressed));
        applyFilters();
      });
    });

    sortBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        currentSort = btn.dataset.sort!;
        sortBtns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-pressed', 'false'); });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        applySort();
      });
    });

    // Collapsible tag row (only used when categories are NOT present)
    const toggle = bar.querySelector<HTMLButtonElement>('#tag-toggle');
    const allTagChips = [...bar.querySelectorAll<HTMLElement>('.tag-chip[data-tag]')];
    if (toggle) {
      const SHOW_N = 8;
      const overflowChips = allTagChips.slice(SHOW_N);
      toggle.addEventListener('click', () => {
        const expanded = toggle.dataset.expanded === 'true';
        overflowChips.forEach(t => t.hidden = expanded);
        toggle.dataset.expanded = String(!expanded);
        toggle.textContent = expanded ? `+${overflowChips.length} more` : 'show less';
        toggle.parentElement?.appendChild(toggle);
      });
    }
  })();
</script>

<style>
  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-block-end: var(--space-xl);
  }

  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
  }

  .filter-row:first-child {
    justify-content: space-between;
  }

  .filter-group,
  .sort-group {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .sort-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-inline-end: 0.15rem;
  }

  .filter-btn,
  .sort-btn,
  .tag-chip {
    cursor: pointer;
    border: 1px solid var(--color-border);
    border-radius: 1.5em;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 0.5em 0.75em;
    min-height: 36px;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .maturity-btn {
    font-size: 1.1rem;
    padding: 0.3em 0.5em;
    min-height: 36px;
    line-height: 1;
  }

  .filter-btn:hover,
  .sort-btn:hover,
  .tag-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn.active,
  .sort-btn.active,
  .tag-chip.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .tag-row {
    gap: var(--space-xs);
  }

  .tag-toggle {
    border-style: dashed;
    opacity: 0.7;
  }
  .tag-toggle:hover {
    opacity: 1;
  }

  /* Category buttons */
  .category-row {
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .category-btn {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    border: 1px solid var(--color-border);
    border-radius: 1.5em;
    background: transparent;
    color: var(--color-text-muted);
    font: inherit;
    font-size: 0.8rem;
    padding: 0.3em 0.8em;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }
  .category-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .category-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .category-emoji {
    font-size: 0.95em;
    line-height: 1;
  }
</style>
