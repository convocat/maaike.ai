---
import settings from '../data/settings.json';
import CollectionIcon from './CollectionIcon.astro';

const collections = [
  { href: '/articles', slug: 'articles', label: 'Articles', desc: settings.articlesDescription },
  { href: '/field-notes', slug: 'field-notes', label: 'Field Notes', desc: settings.fieldNotesDescription },
  { href: '/seeds', slug: 'seeds', label: 'Seeds', desc: settings.seedsDescription },
  { href: '/jottings', slug: 'jottings', label: 'Jottings', desc: settings.jottingsDescription },
  { href: '/weblinks', slug: 'weblinks', label: 'Weblinks', desc: settings.weblinksDescription },
  { href: '/videos', slug: 'videos', label: 'Videos', desc: settings.videosDescription },
  { href: '/experiments', slug: 'experiments', label: 'Experiments', desc: settings.experimentsDescription },
  { href: '/library', slug: 'library', label: 'Library', desc: settings.libraryDescription },
  { href: '/projects', slug: 'projects', label: 'Projects', desc: 'Active and completed projects.' },
];

const navLinks = [
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="site-title">
      {settings.siteTitle}
    </a>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-nav">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Main navigation">
      <ul>
        <li class="garden-dropdown">
          <button class="garden-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            The Garden
            <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
              <path d="M1 1 L5 5 L9 1" />
            </svg>
          </button>
          <div class="garden-mega-menu">
            <div class="mega-collections">
              {collections.map(({ href, slug, label, desc }) => (
                <a href={href} class:list={['mega-item', { active: currentPath.startsWith(href) }]}>
                  <CollectionIcon collection={slug} size={20} />
                  <div>
                    <span class="mega-label">{label}</span>
                    <span class="mega-desc">{desc}</span>
                  </div>
                </a>
              ))}
            </div>
            <div class="mega-views">
              <a href="/" class:list={[{ active: currentPath === '/' }]}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="15" y2="12" /><line x1="3" y1="18" x2="18" y2="18" /></svg>
                Stream
              </a>
              <a href="/explore" class:list={[{ active: currentPath.startsWith('/explore') }]}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10" /><path d="M16.24 7.76l-2.12 6.36-6.36 2.12 2.12-6.36z" /></svg>
                Map
              </a>
              <a href="/collections" class:list={[{ active: currentPath === '/collections' }]}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                Collections
              </a>
              <a href="/stack" class:list={[{ active: currentPath === '/stack' }]}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/><line x1="12" y1="12" x2="12" y2="17"/><line x1="9.5" y1="14.5" x2="14.5" y2="14.5"/></svg>
                Stack
              </a>
              <a href="/graph" class:list={[{ active: currentPath === '/graph' }]}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="12" cy="18" r="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="7" y1="7.5" x2="11" y2="16.5"/><line x1="17" y1="7.5" x2="13" y2="16.5"/></svg>
                Graph
              </a>
            </div>
          </div>
        </li>
        {navLinks.map(({ href, label }) => (
          <li>
            <a href={href} class:list={[{ active: href !== '/' && currentPath.startsWith(href) }]}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a href="/stack" class="header-search-btn" aria-label="Search the garden" title="Search the garden">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </a>

  </div>
</header>

<script>
  function setupMenu() {
    const toggle = document.querySelector('.menu-toggle');
    const nav = document.getElementById('site-nav');
    if (!toggle || !nav) return;

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('open');

      if (!expanded) {
        // Auto-open the garden mega menu on mobile
        const trigger = nav.querySelector('.garden-dropdown-trigger') as HTMLButtonElement | null;
        const dropdown = nav.querySelector('.garden-dropdown') as HTMLElement | null;
        if (trigger && dropdown) {
          trigger.setAttribute('aria-expanded', 'true');
          dropdown.classList.add('open');
        }
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && nav.classList.contains('open')) {
        nav.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (nav.classList.contains('open') && !nav.contains(e.target as Node) && e.target !== toggle && !toggle.contains(e.target as Node)) {
        nav.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }

  function setupGardenDropdown() {
    const trigger = document.querySelector('.garden-dropdown-trigger') as HTMLButtonElement;
    const dropdown = document.querySelector('.garden-dropdown') as HTMLElement;
    if (!trigger || !dropdown) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      dropdown.classList.toggle('open');
    });

    const menuToggle = document.querySelector('.menu-toggle');
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node) && !menuToggle?.contains(e.target as Node)) {
        trigger.setAttribute('aria-expanded', 'false');
        dropdown.classList.remove('open');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dropdown.classList.contains('open')) {
        trigger.setAttribute('aria-expanded', 'false');
        dropdown.classList.remove('open');
        trigger.focus();
      }
    });
  }

  setupMenu();
  setupGardenDropdown();
  document.addEventListener('astro:after-swap', () => { setupMenu(); setupGardenDropdown(); });
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-md);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .site-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-heading);
    text-decoration: none;
    white-space: nowrap;
    padding: var(--space-xs) 0;
  }
  .site-title:hover {
    color: var(--color-accent);
  }

  .site-nav {
    margin-left: auto;
  }

  .site-nav ul {
    display: flex;
    list-style: none;
    padding: 0;
    gap: var(--space-lg);
    align-items: center;
  }

  .site-nav a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }
  .site-nav a:hover,
  .site-nav a.active {
    color: var(--color-accent);
  }

  /* Garden mega dropdown */
  .garden-dropdown {
    position: relative;
  }
  .garden-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    padding: 0;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }
  .garden-dropdown-trigger:hover {
    color: var(--color-accent);
  }
  .garden-dropdown-trigger .chevron {
    transition: transform var(--transition-fast);
  }
  .garden-dropdown.open .garden-dropdown-trigger .chevron {
    transform: rotate(180deg);
  }

  .garden-mega-menu {
    display: none;
    position: absolute;
    top: calc(100% + 12px);
    right: -100px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-lg);
    width: 520px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    z-index: 200;
  }
  .garden-dropdown.open .garden-mega-menu {
    display: block;
  }

  .mega-collections {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xs);
  }

  .mega-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-sm);
    border-radius: 8px;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .mega-item:hover {
    background: var(--color-bg-card);
  }
  .mega-item div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mega-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-heading);
  }
  .mega-item:hover .mega-label {
    color: var(--color-accent);
  }
  .mega-item.active .mega-label {
    color: var(--color-accent);
  }
  .mega-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    white-space: normal;
  }

  .mega-views {
    display: flex;
    gap: var(--space-md);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-md);
    padding-top: var(--space-md);
  }
  .mega-views a {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-xs) var(--space-sm);
    border-radius: 6px;
    transition: all var(--transition-fast);
  }
  .mega-views a:hover {
    color: var(--color-accent);
    background: var(--color-bg-card);
  }
  .mega-views a.active {
    color: var(--color-accent);
    font-weight: 600;
  }

  .header-search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    padding: 8px;
    margin: -8px;
    border-radius: 50%;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .header-search-btn:hover {
    color: var(--color-accent);
    background: var(--color-border);
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 10px;
    margin: -10px;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .header-search-btn { display: none; }

    .menu-toggle {
      display: flex;
    }

    .site-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-md);
      z-index: 100;
    }

    .site-nav.open {
      display: block;
    }

    .site-nav ul {
      flex-direction: column;
      gap: 0;
    }

    .site-nav li a {
      display: block;
      padding: var(--space-sm) var(--space-xs);
      min-height: 44px;
      display: flex;
      align-items: center;
    }

    .garden-mega-menu {
      position: static;
      width: auto;
      border: none;
      box-shadow: none;
      padding: var(--space-sm) 0 var(--space-sm) var(--space-md);
    }

    .mega-collections {
      grid-template-columns: 1fr;
    }

    .mega-views {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .header-inner {
      position: relative;
    }
  }
</style>
